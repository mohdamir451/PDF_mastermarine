@model DashboardVm
@using System.Globalization
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Enterprise validation operations";

    var culture = CultureInfo.InvariantCulture;
    var activePdfRate = Model.TotalPdfSubmissions > 0 ? (double)Model.ActivePdfSubmissions / Model.TotalPdfSubmissions * 100 : 0;
    var reviewTotal = Model.CompletePdfSubmissions + Model.PdfSubmissionsNeedingReview;
    var completeRate = reviewTotal > 0 ? (double)Model.CompletePdfSubmissions / reviewTotal * 100 : 0;
    var fieldMatchRate = Model.TotalComparisonFields > 0 ? (double)Model.MatchedComparisonFields / Model.TotalComparisonFields * 100 : 0;
    var activeUserRate = Model.TotalUsers > 0 ? (double)Model.ActiveUsers / Model.TotalUsers * 100 : 0;
    var maxTrend = Math.Max(1, Model.PdfSubmissionTrend.Any() ? Model.PdfSubmissionTrend.Max(x => x.Count) : 0);
    var maxStatus = Math.Max(1, Model.JobStatusBreakdown.Any() ? Model.JobStatusBreakdown.Max(x => x.Count) : 0);
}

<section class="ops-dashboard">
    <section class="ux-dashboard-priority" aria-label="Priority dashboard insight">
        <div>
            <p>Priority Focus</p>
            <h3>@(Model.PdfSubmissionsNeedingReview > 0 ? "Review PDF records with issues" : "Validation queue is healthy")</h3>
            <span>@(Model.PdfSubmissionsNeedingReview > 0 ? "Start with active records that need review before working on new submissions." : "No submitted PDF records currently need review. Continue monitoring incoming validations.")</span>
        </div>
        <div>
            <strong>@Model.PdfSubmissionsNeedingReview.ToString("N0")</strong>
            <a asp-controller="ComparisonJobs" asp-action="SubmittedPdfData" class="btn btn-primary">Open Review Queue</a>
        </div>
    </section>

    <div class="ops-top-grid">
        <section class="ops-summary-panel">
            <div>
                <p  class="ops-eyebrow">Operations Dashboard</p>
                <span>Live overview of PDF validation records, comparison health, access posture, and audit activity.</span>
            </div>
            <div class="ops-summary-pills" aria-label="Dashboard totals">
                <span><b>@Model.TotalComparisonJobs.ToString("N0")</b> jobs</span>
                <span><b>@Model.TotalPdfSubmissions.ToString("N0")</b> PDF records</span>
                <span><b>@Model.TotalComparisonFields.ToString("N0")</b> fields</span>
            </div>
        </section>

        <section class="ops-activity-card">
            <div class="ops-card-heading">
                <span>Last Activity</span>
                <a asp-controller="Audit" asp-action="Index">View All</a>
            </div>
            <strong>@(Model.LastActivityAt?.ToString("dd MMM, HH:mm") ?? "No activity")</strong>
            <small>Last PDF saved: @(Model.LastPdfSubmittedAt?.ToString("dd MMM, HH:mm") ?? "No PDF submissions")</small>
        </section>
    </div>

    <div class="ops-kpi-grid" aria-label="Executive metrics">
        <article class="ops-kpi accent-blue">
            <span>Active Records</span>
            <strong>@Model.ActivePdfSubmissions.ToString("N0")</strong>
            <small>@activePdfRate.ToString("0.0")% current records</small>
        </article>
        <article class="ops-kpi accent-red">
            <span>Needs Review</span>
            <strong>@Model.PdfSubmissionsNeedingReview.ToString("N0")</strong>
            <small>PDF records with issues</small>
        </article>
        <article class="ops-kpi accent-green">
            <span>Completed</span>
            <strong>@Model.CompletePdfSubmissions.ToString("N0")</strong>
            <small>@completeRate.ToString("0.0")% validation pass rate</small>
        </article>
        <article class="ops-kpi accent-amber">
            <span>Blocking Issues</span>
            <strong>@Model.PendingMismatches.ToString("N0")</strong>
            <small>@Model.BlockingComparisonFields.ToString("N0") blocking fields</small>
        </article>
    </div>

    <div class="ops-health-grid">
        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <h3>Submission Trend</h3>
                    <span>Saved PDF records over the last 7 days</span>
                </div>
                <a asp-controller="ComparisonJobs" asp-action="SubmittedPdfData">View All</a>
            </div>
            <div class="ops-trend-chart">
                @foreach (var point in Model.PdfSubmissionTrend)
                {
                    var height = point.Count > 0 ? Math.Max(10, (double)point.Count / maxTrend * 100) : 3;
                    <div class="ops-trend-item">
                        <div class="ops-trend-column">
                            <div class="ops-trend-bar" style="height:@height.ToString("0.##", culture)%"></div>
                        </div>
                        <strong>@point.Count.ToString("N0")</strong>
                        <span>@point.Date.ToString("dd MMM")</span>
                    </div>
                }
            </div>
        </section>

        <section class="ops-panel">
            <div class="ops-panel-head">
                <div>
                    <h3>Validation Health</h3>
                    <span>Completion and comparison status</span>
                </div>
                <strong>@completeRate.ToString("0.0")%</strong>
            </div>
            <div class="ops-health-content">
                <div class="ops-ring" style="--ring-value:@completeRate.ToString("0.##", culture)">
                    <div>
                        <strong>@Model.CompletePdfSubmissions.ToString("N0")</strong>
                        <span>complete</span>
                    </div>
                </div>
                <div class="ops-status-grid">
                    @if (Model.JobStatusBreakdown.Any())
                    {
                        @foreach (var status in Model.JobStatusBreakdown)
                        {
                            var width = (double)status.Count / maxStatus * 100;
                            <div class="ops-status-mini">
                                <div><span>@status.Status</span><b>@status.Count.ToString("N0")</b></div>
                                <div class="ops-track"><div style="width:@width.ToString("0.##", culture)%"></div></div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="ops-empty compact">No comparison job status rows.</div>
                    }
                </div>
            </div>
        </section>
    </div>

    <div class="ops-data-grid">
        <section class="ops-panel ops-records-panel">
            <div class="ops-panel-head">
                <div>
                    <h3>Recent PDF Records</h3>
                    <span>Primary operational queue for saved validation records</span>
                </div>
                <a asp-controller="ComparisonJobs" asp-action="SubmittedPdfData">View All</a>
            </div>
            <div class="ops-table-wrap">
                <table class="ops-table">
                    <thead>
                        <tr>
                            <th>Bill of Lading</th>
                            <th>Submitted By</th>
                            <th>Validation</th>
                            <th>Saved</th>
                            <th>Quick Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentPdfSubmissions.Any())
                        {
                            @foreach (var item in Model.RecentPdfSubmissions)
                            {
                                var validationClass = item.IssueCount > 0 ? "warning" : "success";
                                <tr>
                                    <td>
                                        <strong>@item.BillOfLadingNumber</strong>
                                        <span title="@item.SourceFileName">@item.SourceFileName</span>
                                    </td>
                                    <td>@item.SubmittedByUserId</td>
                                    <td>
                                        <div class="ops-validation-cell">
                                            <span class="ops-pill @validationClass">@item.ValidationPercent.ToString("0")%</span>
                                            <small>@item.IssueCount.ToString("N0") issues / @item.FieldCount.ToString("N0") fields</small>
                                        </div>
                                    </td>
                                    <td>@item.SubmittedAt.ToString("dd MMM HH:mm")</td>
                                    <td>
                                        <a asp-controller="ComparisonJobs" asp-action="SubmittedPdfData" class="ops-action-link">Open</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5">No PDF submission rows found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="ops-panel ops-audit-panel">
            <div class="ops-panel-head">
                <div>
                    <h3>Audit Activity</h3>
                    <span>Latest 5 security and workflow events</span>
                </div>
                <a asp-controller="Audit" asp-action="Index">View All</a>
            </div>
            <div class="ops-audit-list">
                @if (Model.RecentActivity.Any())
                {
                    @foreach (var activity in Model.RecentActivity)
                    {
                        <article class="ops-audit-item">
                            <div>
                                <strong>@activity.Action</strong>
                                <span>@activity.TargetEntity</span>
                            </div>
                            <small>@activity.PerformedByName · @activity.Timestamp.ToString("dd MMM HH:mm")</small>
                        </article>
                    }
                }
                else
                {
                    <div class="ops-empty compact">No audit log rows found.</div>
                }
            </div>
        </section>
    </div>

    <div class="ops-support-grid">
        <section class="ops-panel compact-widget">
            <div class="ops-panel-head tight">
                <div>
                    <h3>PDF Lifecycle</h3>
                    <span>Current vs replaced records</span>
                </div>
            </div>
            <div class="ops-widget-metrics">
                <div><span>Active</span><strong>@Model.ActivePdfSubmissions.ToString("N0")</strong></div>
                <div><span>Replaced</span><strong>@Model.ReplacedPdfSubmissions.ToString("N0")</strong></div>
            </div>
            <div class="ops-track"><div style="width:@activePdfRate.ToString("0.##", culture)%"></div></div>
        </section>

        <section class="ops-panel compact-widget">
            <div class="ops-panel-head tight">
                <div>
                    <h3>User Access</h3>
                    <span>Account posture</span>
                </div>
                <a asp-controller="Users" asp-action="Index">Users</a>
            </div>
            <div class="ops-widget-metrics four">
                <div><span>Users</span><strong>@Model.TotalUsers.ToString("N0")</strong></div>
                <div><span>Active</span><strong>@Model.ActiveUsers.ToString("N0")</strong></div>
                <div><span>Inactive</span><strong>@Model.InactiveUsers.ToString("N0")</strong></div>
                <div><span>Roles</span><strong>@Model.TotalRoles.ToString("N0")</strong></div>
            </div>
            <div class="ops-track user"><div style="width:@activeUserRate.ToString("0.##", culture)%"></div></div>
        </section>

        <section class="ops-panel compact-widget">
            <div class="ops-panel-head tight">
                <div>
                    <h3>Comparison Fields</h3>
                    <span>Field-level quality</span>
                </div>
                <strong>@fieldMatchRate.ToString("0.0")%</strong>
            </div>
            <div class="ops-widget-metrics four">
                <div><span>Total</span><strong>@Model.TotalComparisonFields.ToString("N0")</strong></div>
                <div><span>Matched</span><strong>@Model.MatchedComparisonFields.ToString("N0")</strong></div>
                <div><span>Blocking</span><strong>@Model.BlockingComparisonFields.ToString("N0")</strong></div>
                <div><span>Pending</span><strong>@Model.PendingMismatches.ToString("N0")</strong></div>
            </div>
        </section>
    </div>
</section>

<style>
    .ops-dashboard {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 0 0 16px;
    }

    .ops-top-grid,
    .ops-health-grid,
    .ops-data-grid,
    .ops-support-grid,
    .ops-kpi-grid {
        display: grid;
        gap: 12px;
    }

    .ops-top-grid {
        grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    }

    .ops-health-grid {
        grid-template-columns: minmax(0, 1.35fr) minmax(420px, .85fr);
    }

    .ops-data-grid {
        grid-template-columns: minmax(0, 1.55fr) minmax(320px, .65fr);
    }

    .ops-support-grid {
        grid-template-columns: .8fr 1fr 1fr;
    }

    .ops-kpi-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .ops-summary-panel,
    .ops-activity-card,
    .ops-panel,
    .ops-kpi {
        border: 1px solid #dbe5f4;
        border-radius: 12px;
        background: linear-gradient(180deg, #fff 0%, #fbfdff 100%);
        box-shadow: 0 10px 26px rgba(15, 23, 42, .055);
    }

    .ops-summary-panel {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: center;
        min-height: 104px;
        padding: 16px 20px;
    }

    .ops-eyebrow {
        margin: 0 0 3px;
        color: #2563eb;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .ops-summary-panel h2 {
        margin: 0;
        color: #061a40;
        font-size: clamp(24px, 2.1vw, 34px);
        line-height: 1.05;
        font-weight: 900;
    }

    .ops-summary-panel span,
    .ops-card-heading span,
    .ops-activity-card small,
    .ops-panel-head span,
    .ops-kpi small,
    .ops-table td span,
    .ops-validation-cell small,
    .ops-audit-item span,
    .ops-audit-item small,
    .ops-widget-metrics span {
        color: #52657f;
    }

    .ops-summary-panel > div:first-child > span {
        display: block;
        margin-top: 5px;
        font-size: 13px;
        line-height: 1.35;
    }

    .ops-summary-pills {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
        min-width: 320px;
    }

    .ops-summary-pills span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 30px;
        padding: 0 10px;
        border: 1px solid #dce7f7;
        border-radius: 999px;
        background: #f8fbff;
        color: #33435f;
        font-size: 12px;
        font-weight: 800;
    }

    .ops-summary-pills b {
        color: #061a40;
        font-size: 14px;
    }

    .ops-activity-card {
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 104px;
        padding: 16px;
    }

    .ops-card-heading,
    .ops-panel-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: flex-start;
    }

    .ops-card-heading span {
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .ops-card-heading a,
    .ops-panel-head a {
        color: #1d4ed8;
        font-size: 12px;
        font-weight: 800;
        text-decoration: none;
        white-space: nowrap;
    }

    .ops-activity-card strong {
        margin: 8px 0 4px;
        color: #061a40;
        font-size: 22px;
        line-height: 1;
        font-weight: 900;
    }

    .ops-activity-card small {
        font-size: 12px;
        font-weight: 700;
    }

    .ops-kpi {
        position: relative;
        overflow: hidden;
        min-height: 92px;
        padding: 14px 16px 13px;
        transition: transform .16s ease, box-shadow .16s ease;
    }

    .ops-kpi:hover {
        transform: translateY(-1px);
        box-shadow: 0 14px 30px rgba(15, 23, 42, .075);
    }

    .ops-kpi:before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 3px;
        background: var(--accent-color);
        opacity: .74;
    }

    .ops-kpi span {
        display: block;
        color: #52657f;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .ops-kpi strong {
        display: block;
        margin: 8px 0 3px;
        color: #061a40;
        font-size: 31px;
        line-height: 1;
        font-weight: 900;
    }

    .accent-blue { --accent-color: #3b82f6; }
    .accent-red { --accent-color: #ef4444; }
    .accent-green { --accent-color: #10b981; }
    .accent-amber { --accent-color: #f59e0b; }

    .ops-panel {
        min-width: 0;
        padding: 14px 16px;
    }

    .ops-panel-head {
        margin-bottom: 12px;
    }

    .ops-panel-head.tight {
        margin-bottom: 10px;
    }

    .ops-panel-head h3 {
        margin: 0 0 2px;
        color: #10233f;
        font-size: 16px;
        line-height: 1.15;
        font-weight: 900;
    }

    .ops-panel-head span {
        display: block;
        font-size: 12px;
        line-height: 1.35;
    }

    .ops-panel-head strong {
        color: #0f766e;
        font-size: 18px;
        line-height: 1;
        font-weight: 900;
    }

    .ops-trend-chart {
        display: grid;
        grid-template-columns: repeat(7, minmax(48px, 1fr));
        gap: 10px;
        min-height: 164px;
        align-items: end;
        padding: 12px;
        border: 1px solid #e5edf7;
        border-radius: 10px;
        background:
            linear-gradient(180deg, rgba(226, 235, 247, .55) 1px, transparent 1px),
            #f8fbff;
        background-size: 100% 40px;
    }

    .ops-trend-item {
        display: grid;
        grid-template-rows: minmax(84px, 1fr) auto auto;
        gap: 5px;
        align-items: end;
        text-align: center;
    }

    .ops-trend-column {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        height: 100%;
    }

    .ops-trend-bar {
        width: min(100%, 58px);
        min-height: 4px;
        border-radius: 7px 7px 3px 3px;
        background: linear-gradient(180deg, #2563eb, #0f766e);
        box-shadow: 0 8px 16px rgba(37, 99, 235, .14);
    }

    .ops-trend-item strong {
        color: #10233f;
        font-size: 13px;
        line-height: 1;
        font-weight: 900;
    }

    .ops-trend-item span {
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
    }

    .ops-health-content {
        display: grid;
        grid-template-columns: 124px minmax(0, 1fr);
        gap: 12px;
        align-items: center;
    }

    .ops-ring {
        display: grid;
        place-items: center;
        width: 116px;
        aspect-ratio: 1;
        border-radius: 50%;
        background: conic-gradient(#0f766e calc(var(--ring-value) * 1%), #e8eef7 0);
    }

    .ops-ring > div {
        display: grid;
        place-items: center;
        width: 72%;
        aspect-ratio: 1;
        border-radius: 50%;
        background: #fff;
    }

    .ops-ring strong {
        color: #061a40;
        font-size: 24px;
        line-height: 1;
        font-weight: 900;
    }

    .ops-ring span {
        color: #52657f;
        font-size: 11px;
        font-weight: 800;
    }

    .ops-status-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .ops-status-mini {
        min-width: 0;
        padding: 9px;
        border: 1px solid #e4ebf6;
        border-radius: 9px;
        background: #f9fbff;
    }

    .ops-status-mini > div:first-child {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        align-items: center;
        margin-bottom: 7px;
    }

    .ops-status-mini span {
        min-width: 0;
        overflow: hidden;
        color: #52657f;
        font-size: 11px;
        font-weight: 800;
        text-overflow: ellipsis;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .ops-status-mini b {
        color: #061a40;
        font-size: 15px;
        line-height: 1;
        font-weight: 900;
    }

    .ops-track {
        height: 7px;
        overflow: hidden;
        border-radius: 999px;
        background: #e8eef7;
    }

    .ops-track div {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #2563eb, #0f766e);
    }

    .ops-track.user div {
        background: linear-gradient(90deg, #6366f1, #2563eb);
    }

    .ops-table-wrap {
        overflow: hidden;
        border: 1px solid #dbe5f4;
        border-radius: 10px;
    }

    .ops-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
    }

    .ops-table th,
    .ops-table td {
        padding: 9px 12px;
        border-bottom: 1px solid #e8eef7;
        text-align: left;
        vertical-align: middle;
    }

    .ops-table th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: #f6f9fd;
        color: #64748b;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .ops-table tbody tr {
        transition: background .16s ease;
    }

    .ops-table tbody tr:hover {
        background: #f8fbff;
    }

    .ops-table td {
        color: #061a40;
        font-size: 13px;
        font-weight: 700;
    }

    .ops-table td:first-child strong,
    .ops-table td:first-child span {
        display: block;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ops-table td:first-child span {
        margin-top: 2px;
        font-size: 11px;
        font-weight: 700;
    }

    .ops-table th:nth-child(1) { width: 27%; }
    .ops-table th:nth-child(2) { width: 21%; }
    .ops-table th:nth-child(3) { width: 20%; }
    .ops-table th:nth-child(4) { width: 16%; }
    .ops-table th:nth-child(5) { width: 16%; }

    .ops-validation-cell {
        display: flex;
        gap: 7px;
        align-items: center;
        min-width: 0;
    }

    .ops-validation-cell small {
        overflow: hidden;
        font-size: 11px;
        font-weight: 700;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ops-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 24px;
        padding: 0 8px;
        border: 1px solid transparent;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
        white-space: nowrap;
    }

    .ops-pill.success {
        border-color: #bbf7d0;
        background: #ecfdf5;
        color: #047857;
    }

    .ops-pill.warning {
        border-color: #fed7aa;
        background: #fff7ed;
        color: #c2410c;
    }

    .ops-action-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 28px;
        padding: 0 12px;
        border: 1px solid #d8e3f2;
        border-radius: 8px;
        background: #f8fbff;
        color: #10233f;
        font-size: 12px;
        font-weight: 900;
        text-decoration: none;
        white-space: nowrap;
    }

    .ops-audit-list {
        display: flex;
        flex-direction: column;
        gap: 7px;
        max-height: 244px;
        overflow: hidden;
    }

    .ops-audit-item {
        padding: 9px 10px;
        border: 1px solid #e4ebf6;
        border-radius: 9px;
        background: #f9fbff;
    }

    .ops-audit-item strong,
    .ops-audit-item span,
    .ops-audit-item small {
        display: block;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
