<style>
    #pdfCompareTable td {
        vertical-align: top;
    }

    .json-details {
        max-width: 680px;
    }

    .json-preview {
        max-width: min(680px, 70vw);
        max-height: 220px;
        overflow: auto;
        margin-top: 10px;
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: #f8fafc;
        color: var(--text);
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 12px;
        line-height: 1.5;
    }

    html[data-theme="dark"] .json-preview {
        background: #121a2d;
    }

    .saved-preview-json {
        max-height: 68vh;
        max-width: none;
        margin: 0;
    }

    .workspace-nav {
        position: sticky;
        top: 0;
        z-index: 15;
        display: flex;
        gap: 4px;
        margin: -10px 0 10px;
        padding: 4px;
        width: max-content;
        border: 1px solid #dbe5f1;
        border-radius: 12px;
        background: var(--bg);
    }

    .workspace-nav a {
        border: 0;
        border-radius: 9px;
        color: var(--text-muted);
        font-size: 13px;
        font-weight: 800;
        padding: 7px 12px;
        text-decoration: none;
        background: transparent;
    }

    .workspace-nav a:hover {
        color: var(--text);
        border-color: var(--primary);
    }

    .submitted-data-head {
        align-items: flex-start;
        gap: 16px;
    }

    .submitted-summary-grid {
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        margin: 14px 0 16px;
    }

    .submitted-summary-card {
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        padding: 12px;
    }

    .submitted-summary-card span {
        color: var(--text-muted);
        display: block;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .submitted-summary-card strong {
        color: var(--title);
        display: block;
        font-size: 22px;
        margin-top: 6px;
    }

    .submitted-summary-card.success {
        border-color: color-mix(in srgb, #16a34a 34%, var(--border));
    }

    .submitted-summary-card.warning {
        border-color: color-mix(in srgb, #f59e0b 42%, var(--border));
    }

    .segmented-control {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        padding: 3px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface-muted);
    }

    .segment-btn {
        min-height: 32px;
        padding: 0 12px;
        border: 0;
        border-radius: 6px;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        font: inherit;
    }

    .segment-btn.is-active {
        background: var(--surface);
        box-shadow: var(--shadow-sm);
        color: var(--text);
        font-weight: 700;
    }

    .submitted-filter-grid {
        align-items: end;
        display: grid;
        gap: 12px;
        grid-template-columns: minmax(220px, 1.4fr) minmax(150px, .7fr) minmax(140px, .6fr) minmax(140px, .6fr) auto;
        margin-bottom: 12px;
    }

    .submitted-sticky-toolbar {
        position: sticky;
        top: 48px;
        z-index: 12;
        padding: 10px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: color-mix(in srgb, var(--surface) 94%, transparent);
        backdrop-filter: blur(10px);
    }

    .submitted-export-actions {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }

    .field-count-note {
        color: var(--text-muted);
        display: block;
        font-size: 12px;
        margin-top: 4px;
        white-space: nowrap;
    }

    .status-chip-visual::before {
        content: "";
        display: inline-block;
        width: 7px;
        height: 7px;
        margin-right: 6px;
        border-radius: 999px;
        background: currentColor;
        vertical-align: middle;
    }

    tr.submitted-row-hidden {
        display: none;
    }

    tr[data-active="false"] {
        background: color-mix(in srgb, var(--surface-muted) 65%, transparent);
    }

    .saved-row-json {
        display: none;
    }

    #savedSubmissionPreviewModal.drawer-backdrop {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: none;
        align-items: stretch;
        justify-content: flex-end;
        background: rgba(15, 23, 42, .55);
    }

    #savedSubmissionPreviewModal.drawer-backdrop.is-open {
        display: flex;
    }

    #savedSubmissionPreviewModal.drawer-backdrop.show {
        display: flex;
    }

    #savedSubmissionPreviewModal .detail-drawer {
        position: relative;
        z-index: 10001;
        flex: 0 0 760px;
        width: 760px;
        max-width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: var(--surface, #ffffff);
        color: var(--text, #172033);
        box-shadow: -24px 0 60px rgba(15, 23, 42, .34);
        border-left: 1px solid var(--border, #dbe5f4);
    }

    .drawer-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 16px;
        border-bottom: 1px solid var(--border, #dbe5f4);
        background: var(--surface, #ffffff);
    }

    .drawer-head h3 {
        color: var(--title);
        margin: 0;
    }

    .drawer-tabs {
        display: flex;
        gap: 6px;
        padding: 10px 16px;
        border-bottom: 1px solid var(--border, #dbe5f4);
        background: var(--surface-muted, #f4f7fb);
    }

    .drawer-tab {
        border: 1px solid transparent;
        border-radius: 8px;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        font: inherit;
        font-weight: 700;
        padding: 8px 12px;
    }

    .drawer-tab.is-active {
        border-color: var(--border, #dbe5f4);
        background: var(--surface, #ffffff);
        color: var(--text, #172033);
    }

    .drawer-body {
        min-height: 0;
        flex: 1;
        overflow: auto;
        padding: 16px;
        background: var(--surface, #ffffff);
    }

    .drawer-pane {
        display: none;
    }

    .drawer-pane.is-active {
        display: block;
    }

    .saved-summary-list {
        display: grid;
        gap: 10px;
    }

    .saved-summary-item {
        display: grid;
        grid-template-columns: 190px minmax(0, 1fr);
        gap: 12px;
        padding: 12px;
        border: 1px solid var(--border, #dbe5f4);
        border-radius: 8px;
        background: var(--surface, #ffffff);
    }

    .saved-summary-item span {
        color: var(--text-muted);
        font-weight: 700;
    }

    .saved-values-filter {
        margin-bottom: 12px;
    }

    .saved-values-wrap {
        max-height: calc(100vh - 250px);
    }

    .toast-stack {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 100;
        display: grid;
        gap: 10px;
        width: min(380px, calc(100vw - 32px));
    }

    .app-toast {
        border: 1px solid var(--border);
        border-left: 4px solid var(--primary);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow-lg);
        color: var(--text);
        padding: 12px 14px;
        font-weight: 700;
    }

    @@media (max-width: 1080px) {
        .submitted-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .submitted-filter-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .submitted-export-actions {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 720px) {
        .workspace-nav,
        .submitted-data-head,
        .submitted-export-actions {
            align-items: stretch;
            flex-direction: column;
        }

        .submitted-summary-grid,
        .submitted-filter-grid {
            grid-template-columns: 1fr;
        }

        #savedSubmissionPreviewModal .detail-drawer {
            flex-basis: 100vw;
            width: 100vw;
        }
    }

    .validation-shell {
        display: grid;
        gap: 6px;
    }

    .validation-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
    }

    .validation-summary-card {
        border: 1px solid #dbe5f1;
        background: linear-gradient(180deg, #fff, #fbfdff);
        border-radius: 12px;
        padding: 9px 12px;
        min-height: 58px;
        display: grid;
        align-content: center;
        gap: 4px;
        box-shadow: 0 3px 10px rgba(15, 23, 42, .04);
    }

    .validation-summary-card span {
        color: var(--muted);
        font-size: 10.5px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .validation-summary-card strong {
        color: var(--title);
        font-size: 24px;
        line-height: 1;
    }

    .validation-summary-card:nth-child(2) strong { color: #15803d; }

    .validation-summary-card.issue strong {
        color: #b91c1c;
    }

    .validation-summary-card.accuracy strong {
        color: #1d4ed8;
    }

    .validation-progress {
        display: grid;
        gap: 5px;
        padding: 8px 10px;
        border: 1px solid #dbe5f1;
        border-radius: 12px;
        background: #fff;
    }

    .validation-progress-label {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--muted);
        font-size: 12px;
    }

    .validation-progress-label strong {
        color: var(--title);
    }

    .validation-progress-track {
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: #e5edf7;
    }

    .validation-progress-track span {
        display: block;
        width: 0%;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #2563eb, #60a5fa);
        transition: width .2s ease;
    }

    .validation-toolbar {
        position: sticky;
        top: 0;
        z-index: 18;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: rgba(255, 255, 255, .96);
        backdrop-filter: blur(10px);
        min-height: 56px;
        padding: 8px;
        display: block;
        gap: 8px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .045);
        overflow: visible;
    }

    html[data-theme="dark"] .validation-toolbar {
        background: rgba(18, 26, 45, .96);
    }

    .validation-title {
        display: none;
    }

    .validation-title h3,
    .workspace-panel-head h3 {
        color: var(--title);
        font-size: 14px;
        line-height: 1.2;
    }

    .validation-title .form-help {
        max-width: 150px;
        margin: 1px 0 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .workspace-command-bar,
    .workspace-command-secondary {
        display: flex;
        align-items: center;
        gap: 5px;
        flex-wrap: wrap;
    }

    .workspace-command-bar {
        display: flex;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 8px;
        width: 100%;
    }

    .workspace-command-secondary {
        flex: 0 0 auto;
        min-height: 32px;
        padding: 0;
        border: 0;
        border-radius: 0;
        background: transparent;
        flex-wrap: nowrap;
        gap: 8px;
    }

    .workspace-command-secondary[aria-label="View controls"] {
        display: none;
    }

    .workspace-command-secondary[aria-label="Review controls"] {
        order: 1;
    }

    .workspace-command-secondary[aria-label="Filter controls"] {
        order: 2;
        flex: 1 1 420px;
    }

    .workspace-command-secondary[aria-label="Export controls"] {
        order: 3;
        flex: 1 0 100%;
        justify-content: flex-end;
        padding-top: 8px;
        border-top: 1px solid #edf2f7;
    }

    .workspace-command-secondary[aria-label="Export controls"] .issue-toggle {
        margin-right: auto;
    }

    .workspace-command-secondary .btn,
    .workspace-command-secondary input,
    .workspace-command-secondary select {
        min-height: 32px;
        font-size: 12px;
    }

    .workspace-command-secondary .btn,
    .workspace-command-secondary input,
    .workspace-command-secondary select,
    .workspace-command-secondary .issue-counter-pill {
        min-height: 32px;
    }

    .workspace-command-secondary input {
        flex: 1 1 260px;
        width: auto;
        padding-block: 4px;
    }

    .workspace-command-secondary select {
        flex: 0 0 150px;
    }

    .validation-toolbar .btn,
    .validation-toolbar input,
    .validation-toolbar select,
    .pdf-viewer-tools .btn {
        transition: border-color .14s ease, background-color .14s ease, color .14s ease, box-shadow .14s ease, transform .14s ease;
    }

    .validation-toolbar .btn:hover,
    .pdf-viewer-tools .btn:hover {
        transform: translateY(-1px);
    }

    .validation-toolbar .btn:focus-visible,
    .validation-toolbar input:focus-visible,
    .validation-toolbar select:focus-visible,
    .pdf-viewer-tools .btn:focus-visible {
        outline: 0;
        border-color: #93c5fd;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, .14);
    }

    .command-label {
        color: #64748b;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: .06em;
        padding: 0 4px;
        text-transform: uppercase;
    }

    .issue-counter-pill {
        min-height: 32px;
        display: inline-flex;
        align-items: center;
        padding: 0 8px;
        border-radius: 999px;
        background: #eef4ff;
        color: #1e3a8a;
        font-size: 11px;
        font-weight: 800;
    }

    .btn-icon {
        min-width: 36px;
        padding-inline: 8px;
    }

    .issue-toggle {
        min-height: 32px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #dbe5f1;
        border-radius: 999px;
        background: #fff;
        color: #334155;
        cursor: pointer;
        font-size: 12px;
        font-weight: 750;
        padding: 0 10px 0 6px;
        transition: border-color .14s ease, background-color .14s ease, box-shadow .14s ease, color .14s ease;
        user-select: none;
        white-space: nowrap;
    }

    .issue-toggle input {
        position: absolute;
        inline-size: 1px;
        block-size: 1px;
        opacity: 0;
        pointer-events: none;
    }

    .toggle-track {
        position: relative;
        width: 30px;
        height: 18px;
        border-radius: 999px;
        background: #cbd5e1;
        box-shadow: inset 0 0 0 1px rgba(15, 23, 42, .05);
        transition: background-color .14s ease;
    }

    .toggle-track::after {
        content: "";
        position: absolute;
        top: 3px;
        left: 3px;
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: #fff;
        box-shadow: 0 1px 3px rgba(15, 23, 42, .22);
        transition: transform .14s ease;
    }

    .issue-toggle:hover {
        border-color: #b8c8dc;
        background: #f8fafc;
    }

    .issue-toggle:focus-within {
        border-color: #93c5fd;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, .14);
    }

    .issue-toggle:has(input:checked) {
        border-color: #bfdbfe;
        background: #eff6ff;
        color: #1d4ed8;
    }

    .issue-toggle:has(input:checked) .toggle-track {
        background: #2563eb;
    }

    .issue-toggle:has(input:checked) .toggle-track::after {
        transform: translateX(12px);
    }

    .validation-command-groups {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .command-group {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px;
        border: 1px solid #eef2f7;
        border-radius: 8px;
        background: #f8fafc;
    }

    html[data-theme="dark"] .command-group {
        border-color: var(--border);
        background: #111a2b;
    }

    .command-group .btn {
        white-space: nowrap;
    }

    .command-group .btn.is-active {
        border-color: #bfdbfe;
        background: #eff6ff;
        color: #1d4ed8;
    }

    .validation-workspace {
        --pdf-panel-size: 60;
        --matrix-panel-size: 40;
        --detail-panel-size: 20;
        display: grid;
        grid-template-columns:
            minmax(320px, calc(var(--pdf-panel-size) * 1%))
            8px
            minmax(420px, calc(var(--matrix-panel-size) * 1%));
        gap: 0;
        height: clamp(600px, calc(100vh - 132px), 860px);
        min-height: 0;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--card-bg);
        overflow: hidden;
    }

    .validation-workspace.three-column {
        grid-template-columns:
            minmax(260px, calc(var(--pdf-panel-size) * 1%))
            8px
            minmax(420px, calc(var(--matrix-panel-size) * 1%))
            8px
            minmax(240px, calc(var(--detail-panel-size) * 1%));
    }

    .workspace-panel {
        min-width: 0;
        min-height: 0;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        background: var(--card-bg);
    }

    .workspace-panel-head {
        min-height: 40px;
        padding: 8px 12px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        background: linear-gradient(180deg, #fff, #fbfdff);
    }

    .workspace-panel-head > div:first-child {
        min-width: 0;
        display: flex;
        align-items: baseline;
        gap: 8px;
    }

    html[data-theme="dark"] .workspace-panel-head {
        background: linear-gradient(180deg, #121a2d, #111827);
    }

    .workspace-panel-head span {
        display: block;
        margin-top: 0;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .pdf-scroll-region {
        min-height: 0;
        overflow: auto;
        padding: 8px;
        background: #f8fafc;
        position: relative;
    }

    html[data-theme="dark"] .pdf-scroll-region {
        background: #0f172a;
    }

    .validation-workspace .pdf-frame {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 520px;
        border: 1px solid #dbe5f1;
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 8px 20px rgba(15, 23, 42, .07);
    }

    .validation-workspace .pdf-frame:focus,
    .validation-workspace .pdf-frame:focus-visible,
    .pdf-scroll-region:focus-within {
        outline: 0;
        border-color: #cbd5e1;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .09), 0 0 0 1px rgba(148, 163, 184, .22);
    }

    .pdf-selection-pulse {
        position: absolute;
        z-index: 2;
        left: 22px;
        right: 22px;
        top: 22px;
        height: 52px;
        border: 2px solid rgba(37, 99, 235, .55);
        border-radius: 10px;
        background: rgba(37, 99, 235, .08);
        pointer-events: none;
        animation: pdfPulse 1.15s ease-out;
    }

    @@keyframes pdfPulse {
        0% { box-shadow: 0 0 0 0 rgba(37, 99, 235, .35); }
        100% { box-shadow: 0 0 0 12px rgba(37, 99, 235, 0); }
    }

    .pdf-viewer-tools {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0;
        border: 0;
        border-radius: 10px;
        background: transparent;
    }

    .pdf-viewer-tools .btn,
    .pdf-viewer-tools .badge {
        min-height: 28px;
        border-radius: 8px;
        font-size: 11px;
        padding-inline: 8px;
    }

    .pdf-viewer-tools .btn {
        border-color: #e5edf7;
        background: #fff;
        color: #475569;
        box-shadow: 0 1px 2px rgba(15, 23, 42, .035);
    }

    .pdf-viewer-tools .btn:hover {
        border-color: #cbd5e1;
        background: #f8fafc;
        color: var(--title);
    }

    .pdf-viewer-tools .btn:focus-visible {
        outline: 0;
        border-color: #cbd5e1;
        background: #fff;
        box-shadow: 0 1px 2px rgba(15, 23, 42, .04), 0 0 0 2px rgba(148, 163, 184, .18);
        transform: none;
    }

    .pdf-viewer-tools .badge {
        border-color: transparent;
        background: #f1f5f9;
        color: #64748b;
    }

    .workspace-resizer {
        cursor: col-resize;
        background: linear-gradient(90deg, transparent, #dbeafe, transparent);
        position: relative;
        z-index: 5;
    }

    .workspace-resizer::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 3px;
        height: 48px;
        border-radius: 999px;
        background: #94a3b8;
        transform: translate(-50%, -50%);
        opacity: .75;
    }

    .workspace-resizer:hover::after,
    .workspace-resizer.is-dragging::after {
        background: var(--primary);
        opacity: 1;
    }

    .field-details-panel,
    .details-resizer {
        display: none;
    }

    .validation-workspace.three-column .field-details-panel,
    .validation-workspace.three-column .details-resizer {
        display: grid;
    }

    .matrix-panel {
        border-left: 1px solid var(--border);
        grid-template-rows: auto auto minmax(0, 1fr);
    }

    .matrix-head {
        align-items: center;
    }

    .issue-panel {
        position: sticky;
        top: 0;
        z-index: 3;
        display: grid;
        gap: 8px;
        max-height: 88px;
        overflow: auto;
        padding: 8px;
        border-bottom: 1px solid var(--border);
        background: #fff;
    }

    .issue-panel-head {
        color: #334155;
        font-size: 12px;
    }

    .issue-list {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .issue-list button {
        border: 1px solid #fecaca;
        border-radius: 999px;
