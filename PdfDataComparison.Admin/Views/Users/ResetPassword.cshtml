@model UserResetPasswordVm
@{
    ViewData["Title"] = "Reset User Password";
    ViewData["Subtitle"] = "Set a new temporary password for a user account.";
}

<section class="page-hero">
    <div>
        <h2>Reset User Password</h2>
        <p>Set a new password for <strong>@Model.FullName</strong> and share it through your approved internal process.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to Users</a>
</section>

<section class="card form-card">
    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="FullName" type="hidden" />
        <input asp-for="Email" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>

        <div class="form-grid">
            <div class="form-group">
                <label>Email Address</label>
                <input value="@Model.Email" readonly />
            </div>
            <div class="form-group">
                <label>User</label>
                <input value="@Model.FullName" readonly />
            </div>
            <div class="form-group">
                <label asp-for="NewPassword" class="required">New Password</label>
                <input asp-for="NewPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
                <span class="form-help">Password must meet the configured Identity policy.</span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword" class="required">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
            </div>
        </div>

        <div class="alert warning">
            After reset, the user should sign in with this password and change it from Profile Settings.
        </div>

        <div class="toolbar">
            <button class="btn btn-primary" type="submit">Reset Password</button>
            <a asp-action="Index" class="btn btn-ghost">Back to Users</a>
        </div>
    </form>
</section>
