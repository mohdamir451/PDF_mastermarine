@model UserCreateVm
@{
    ViewData["Title"] = "Create User";
    ViewData["Subtitle"] = "Prepare user profile and role assignment details.";
}

<section class="iam-shell" data-iam-page>
    <nav class="iam-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Dashboard" asp-action="Index">Administration</a>
        <span aria-hidden="true">/</span>
        <a asp-action="Index">Users</a>
        <span aria-hidden="true">/</span>
        <strong>Create User</strong>
    </nav>

    <header class="iam-hero">
        <div class="iam-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false"><path d="M12 12.25a4.75 4.75 0 1 0 0-9.5 4.75 4.75 0 0 0 0 9.5Zm0-7.5a2.75 2.75 0 1 1 0 5.5 2.75 2.75 0 0 1 0-5.5Zm0 9.25c-4.42 0-8 2.24-8 5v1.25h16V19c0-2.76-3.58-5-8-5Zm-5.69 4.25C6.95 17 9.12 16 12 16s5.05 1 5.69 2.25H6.31Z" /></svg>
        </div>
        <div>
            <h2>Create User</h2>
            <p>Provision an account, assign a role, and control activation.</p>
        </div>
    </header>

    <div class="iam-layout">
        <section class="iam-form-panel" aria-labelledby="userInfoTitle">
            <div class="iam-section-head">
                <div>
                    <h3 id="userInfoTitle">User Information</h3>
                    <p>Define profile, credentials, and default access for the new account.</p>
                </div>
                <span class="iam-pill">New Account</span>
            </div>

            <form asp-action="Create" method="post" class="iam-form" novalidate data-clear-draft-on-submit>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="iam-validation-summary"></div>

                <div class="iam-form-grid">
                    <div class="iam-field">
                        <label asp-for="FullName" class="required">Full Name</label>
                        <input asp-for="FullName" placeholder="Aarav Mehta" autocomplete="name" data-iam-preview-source="fullName" />
                        <span class="iam-help">Use the employee's official display name.</span>
                        <span asp-validation-for="FullName" class="iam-error"></span>
                    </div>
                    <div class="iam-field">
                        <label asp-for="Email" class="required">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="name@company.com" autocomplete="email" data-iam-preview-source="email" />
                        <span class="iam-help">Email must be unique in this workspace.</span>
                        <span asp-validation-for="Email" class="iam-error"></span>
                    </div>
                    <div class="iam-field">
                        <label asp-for="Department" class="required">Department</label>
                        <input asp-for="Department" placeholder="Operations" data-iam-preview-source="department" />
                        <span class="iam-help">Department helps administrators filter access ownership.</span>
                        <span asp-validation-for="Department" class="iam-error"></span>
                    </div>
                    <div class="iam-field">
                        <label asp-for="RoleName" class="required">Default Role</label>
                        <select asp-for="RoleName" data-iam-preview-source="roleName">
                            <option value="">No role</option>
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        <span class="iam-help">Assign the minimum role needed for this user's responsibilities.</span>
                        <span asp-validation-for="RoleName" class="iam-error"></span>
                    </div>
                    <div class="iam-field">
                        <label asp-for="Password" class="required">Password</label>
                        <input asp-for="Password" type="password" autocomplete="new-password" />
                        <span class="iam-help">Minimum 8 characters with a digit and a special character.</span>
                        <span asp-validation-for="Password" class="iam-error"></span>
                    </div>
                    <div class="iam-field">
                        <label asp-for="ConfirmPassword" class="required">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
                        <span class="iam-help">Re-enter the temporary password before provisioning.</span>
                        <span asp-validation-for="ConfirmPassword" class="iam-error"></span>
                    </div>
                </div>

                <div class="iam-toggle-card">
                    <div>
                        <strong>Account Activation</strong>
                        <span>Activated users can sign in after creation.</span>
                    </div>
                    <label class="iam-switch">
                        <input asp-for="IsActive" data-iam-active-source />
                        <span class="iam-switch-track" aria-hidden="true"></span>
                        <span>Active</span>
                    </label>
                </div>

                <div class="iam-actions">
                    <button class="btn btn-primary" type="submit">Create User</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    <a asp-action="Index" class="btn btn-ghost">Back to Users</a>
                </div>
            </form>
        </section>

        <aside class="iam-side-panel" aria-label="User creation context">
            <section class="iam-preview-card" aria-labelledby="userPreviewTitle">
                <div class="iam-side-head">
                    <h3 id="userPreviewTitle">Account Preview</h3>
                    <span class="iam-pill active" data-iam-preview-status>Active</span>
                </div>
                <dl class="iam-preview-list">
                    <div><dt>Name</dt><dd data-iam-preview="fullName">Aarav Mehta</dd></div>
                    <div><dt>Email</dt><dd data-iam-preview="email">name@company.com</dd></div>
                    <div><dt>Department</dt><dd data-iam-preview="department">Operations</dd></div>
                    <div><dt>Role</dt><dd data-iam-preview="roleName">Not assigned</dd></div>
                    <div><dt>Status</dt><dd><span class="iam-pill active" data-iam-preview-status-text>Active</span></dd></div>
                </dl>
            </section>

            <section class="iam-guidelines-card" aria-labelledby="userGuidelinesTitle">
                <h3 id="userGuidelinesTitle">User Provisioning Guidelines</h3>
                <ul>
                    <li>Use verified business email addresses.</li>
                    <li>Assign the least-privilege default role.</li>
                    <li>Deactivate accounts until onboarding is approved.</li>
                    <li>Reset temporary passwords after first sign-in.</li>
                </ul>
            </section>
        </aside>
    </div>
</section>

<script>
(() => {
    const shell = document.querySelector('[data-iam-page]');
    if (!shell) return;
    const form = shell.querySelector('.iam-form');
    const defaults = { fullName: 'Aarav Mehta', email: 'name@company.com', department: 'Operations', roleName: 'Not assigned' };
    const activeInput = shell.querySelector('[data-iam-active-source]');
    const statusNodes = shell.querySelectorAll('[data-iam-preview-status], [data-iam-preview-status-text]');
    const update = (field) => {
        const key = field.dataset.iamPreviewSource;
        const target = shell.querySelector(`[data-iam-preview="${key}"]`);
        if (target) target.textContent = field.value.trim() || defaults[key] || '-';
    };
    const updateStatus = () => {
        const active = !activeInput || activeInput.checked;
        statusNodes.forEach((node) => {
            node.textContent = active ? 'Active' : 'Inactive';
            node.classList.toggle('active', active);
            node.classList.toggle('inactive', !active);
        });
    };
    shell.querySelectorAll('[data-iam-preview-source]').forEach((field) => {
        field.addEventListener('input', () => update(field));
        field.addEventListener('change', () => update(field));
        field.addEventListener('blur', () => field.closest('.iam-field')?.classList.add('is-touched'));
        update(field);
    });
    activeInput?.addEventListener('change', updateStatus);
    form?.addEventListener('submit', () => {
        form.classList.add('was-submitted');
        shell.querySelectorAll('.iam-field').forEach((group) => group.classList.add('is-touched'));
    });
    updateStatus();
})();
</script>
