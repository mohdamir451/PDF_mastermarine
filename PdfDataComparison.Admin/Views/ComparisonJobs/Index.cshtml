@model PagedResult<ComparisonJobListItemVm>
@{ ViewData["Title"] = "PDF Comparison Jobs"; }
<div class="card"><table class="table"><thead><tr><th>Job</th><th>Title</th><th>Status</th><th>Date</th><th></th></tr></thead><tbody>
@foreach(var j in Model.Items){<tr><td>@j.JobNumber</td><td>@j.Title</td><td><span class="badge">@j.Status</span></td><td>@j.CreatedAt.ToString("yyyy-MM-dd")</td><td><a asp-action="Screen" asp-route-id="@j.Id">Open</a></td></tr>}
</tbody></table></div>
