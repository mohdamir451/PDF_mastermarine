@{ ViewData["Title"] = "Profile / Change Password"; }
<div class="card form-card"><h3>Change Password</h3>
@if(TempData["Message"]!=null){<div class="alert success">@TempData["Message"]</div>}
<form method="post">@Html.AntiForgeryToken()<label>Current Password <input name="currentPassword" type="password"/></label><label>New Password <input name="newPassword" type="password"/></label><button class="btn-primary">Update</button></form>
</div>
