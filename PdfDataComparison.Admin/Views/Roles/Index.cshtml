@model List<PdfDataComparison.Admin.Domain.Entities.ApplicationRole>
@using PdfDataComparison.Admin.Constants
@{
    ViewData["Title"] = "Role Management";
    ViewData["Subtitle"] = "Configure role definitions and governance coverage.";
}

<section class="role-table-page">
    <header class="role-table-hero">
        <div>
            <h2>Role Management</h2>
        </div>
        <div class="role-table-actions">
            <span class="role-count-pill">@Model.Count roles</span>
            <a asp-action="Create" class="btn btn-primary">Create Role</a>
        </div>
    </header>

    <section class="role-table-panel">
      

        @if (Model.Any())
        {
            <div class="role-table-toolbar" aria-label="Role table controls">
                <div class="role-table-search">
                    <label for="roleTableSearch">Search</label>
                    <input id="roleTableSearch" type="search" placeholder="Search roles..." />
                </div>
                <div class="role-table-page-size">
                    <label for="roleTablePageSize">Rows</label>
                    <select id="roleTablePageSize">
                        <option value="5">5 rows</option>
                        <option value="10" selected>10 rows</option>
                        <option value="25">25 rows</option>
                        <option value="50">50 rows</option>
                    </select>
                </div>
                <span class="role-table-count" id="roleTableCount" aria-live="polite">0/0</span>
            </div>

            <div class="table-wrap role-bootstrap-table-wrap">
                <table class="table table-responsive-card role-bootstrap-table" id="roleTable">
                    <thead>
                    <tr>
                        <th scope="col">Role</th>
                        <th scope="col">Description</th>
                        <th scope="col">Status</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var role in Model)
                    {
                        var hasDescription = !string.IsNullOrWhiteSpace(role.Description);
                        var description = hasDescription ? role.Description : "-";

                        <tr>
                            <td data-label="Role">
                                <strong>@role.Name</strong>
                            </td>
                            <td data-label="Description" class="role-description" title="@description">@description</td>
                            <td data-label="Status">
                                <span class="role-status-badge @(hasDescription ? "documented" : "needs-description")">
                                    @(hasDescription ? "Documented" : "Needs Description")
                                </span>
                            </td>
                            <td class="role-row-actions text-end" data-label="Actions">
                                <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-secondary btn-small">Edit</a>
                                <details class="row-menu admin-row-menu role-more-menu">
                                    <summary>More</summary>
                                    <div class="row-menu-list">
                                        @if (User.HasClaim("permission", PermissionCatalog.PermissionsManage) || User.IsInRole("SuperAdmin"))
                                        {
                                            <a asp-controller="Permissions" asp-action="Index">Manage Permissions</a>
                                        }
                                        <a asp-action="Create">Create Similar Role</a>
                                    </div>
                                </details>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="role-table-pagination" aria-label="Role table pages">
                <button type="button" class="btn btn-ghost btn-small" id="rolePrevPageBtn">Previous</button>
                <span class="badge neutral" id="rolePageInfo">Page 1 of 1</span>
                <button type="button" class="btn btn-ghost btn-small" id="roleNextPageBtn">Next</button>
            </div>
        }
        else
        {
            <div class="empty-state role-empty-state">
                <div class="empty-state-icon">IAM</div>
                <h3>No roles defined</h3>
                <p>Create a role to start configuring permission governance and access ownership.</p>
                <div class="empty-actions">
                    <a asp-action="Create" class="btn btn-primary">Create Role</a>
                </div>
            </div>
        }
    </section>
</section>

<style>
    .role-table-page {
        display: grid;
        gap: 16px;
    }

    .role-table-hero,
    .role-table-panel {
        background: #fff;
        border: 1px solid #d9e2ef;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .045);
    }

    .role-table-hero {
        align-items: center;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        min-height: 76px;
        padding: 18px 24px;
    }

    .role-table-hero h2 {
        color: #0f172a;
        font-size: clamp(28px, 2.4vw, 38px);
        font-weight: 900;
        line-height: 1.05;
    }

    .role-table-hero p {
        color: #667085;
        font-size: 13px;
        margin-top: 6px;
    }

    .role-table-actions {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
    }

    .role-count-pill {
        align-items: center;
        background: #eef4ff;
        border: 1px solid #cfe0ff;
        border-radius: 999px;
        color: #1e3a8a;
        display: inline-flex;
        font-size: 12px;
        font-weight: 850;
        min-height: 34px;
        padding: 0 12px;
        white-space: nowrap;
    }

    .role-table-panel {
        overflow: hidden;
    }

    .role-table-panel-head {
        align-items: center;
        border-bottom: 1px solid #d9e2ef;
        display: flex;
        justify-content: space-between;
        padding: 14px 18px;
    }

    .role-table-panel-head h3 {
        color: #0f172a;
        font-size: 20px;
        font-weight: 900;
    }

    .role-table-panel-head p {
        color: #667085;
        font-size: 13px;
        margin-top: 4px;
    }

    .role-table-toolbar {
        align-items: end;
        background: #f8fafc;
        border-bottom: 1px solid #d9e2ef;
        display: grid;
        gap: 10px;
        grid-template-columns: minmax(260px, 1fr) 150px auto;
        padding: 10px 18px;
    }

    .role-table-search,
    .role-table-page-size {
        display: grid;
        gap: 4px;
        min-width: 0;
    }

    .role-table-search label,
    .role-table-page-size label {
        color: #344054;
        font-size: 11px;
        font-weight: 850;
    }

    .role-table-search input,
    .role-table-page-size select {
        border: 1px solid #d9e2ef;
        border-radius: 8px;
        color: #0f172a;
        font-size: 13px;
        min-height: 34px;
        padding: 0 10px;
        width: 100%;
    }

    .role-table-search input:focus,
    .role-table-page-size select:focus {
        border-color: #93c5fd;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, .13);
        outline: 0;
    }

    .role-table-count {
        align-items: center;
        align-self: end;
        background: #eef4ff;
        border: 1px solid #cfe0ff;
        border-radius: 8px;
        color: #1e3a8a;
        display: inline-flex;
        font-size: 12px;
        font-weight: 850;
        justify-content: center;
        min-height: 34px;
        min-width: 76px;
        padding: 0 10px;
    }

    .role-bootstrap-table-wrap {
        border: 0;
        border-radius: 0;
        box-shadow: none;
        max-height: calc(100vh - 250px);
        overflow: auto;
    }

    .role-bootstrap-table {
        margin: 0;
        table-layout: fixed;
        width: 100%;
    }

    .role-bootstrap-table thead th {
        background: #f8fafc;
        border-bottom: 1px solid #d9e2ef;
        color: #64748b;
        font-size: 11px;
        font-weight: 850;
        letter-spacing: .045em;
        padding: 10px 14px;
        position: sticky;
        text-transform: uppercase;
        top: 0;
        z-index: 2;
    }

    .role-bootstrap-table tbody td {
        border-bottom: 1px solid #edf2f7;
        color: #0f172a;
        font-size: 13px;
        height: 48px;
        padding: 8px 14px;
        vertical-align: middle;
    }

    .role-bootstrap-table tbody tr:nth-child(even) {
        background: #fbfcfe;
    }

    .role-bootstrap-table tbody tr:hover {
        background: #f8fbff;
    }

    .role-bootstrap-table th:nth-child(1),
    .role-bootstrap-table td:nth-child(1) { width: 24%; }
    .role-bootstrap-table th:nth-child(2),
    .role-bootstrap-table td:nth-child(2) { width: 46%; }
    .role-bootstrap-table th:nth-child(3),
    .role-bootstrap-table td:nth-child(3) { width: 16%; }
    .role-bootstrap-table th:nth-child(4),
    .role-bootstrap-table td:nth-child(4) { width: 14%; }

    .role-description {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .role-status-badge {
        align-items: center;
        border-radius: 999px;
        display: inline-flex;
        font-size: 11px;
        font-weight: 850;
        min-height: 24px;
        padding: 0 8px;
        white-space: nowrap;
    }

    .role-status-badge.documented {
        background: #dcfce7;
        color: #166534;
    }

    .role-status-badge.needs-description {
        background: #fef3c7;
        color: #92400e;
    }

    .text-end {
        text-align: right;
    }

    .role-row-actions {
        white-space: nowrap;
    }

    .role-row-actions .btn,
    .role-more-menu summary {
        min-height: 30px;
        padding-inline: 10px;
    }

    .role-more-menu {
        display: inline-block;
        margin-left: 6px;
        vertical-align: middle;
    }

    .role-empty-state {
        min-height: 340px;
    }

    .role-table-pagination {
        align-items: center;
        border-top: 1px solid #edf2f7;
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        padding: 10px 18px;
    }

    .role-table-pagination .btn,
    .role-table-pagination .badge {
        min-height: 32px;
    }

    .role-table-pagination .btn:disabled {
        background: #f8fafc;
        border-color: #edf2f7;
        color: #94a3b8;
        cursor: not-allowed;
    }

    .role-table-pagination .badge {
        background: #eef4ff;
        border-color: #cfe0ff;
        color: #1e3a8a;
        font-weight: 850;
    }

    tr.role-row-hidden {
        display: none;
    }

    @@media (max-width: 900px) {
        .role-table-hero {
            align-items: flex-start;
            flex-direction: column;
        }

        .role-table-actions {
            justify-content: flex-start;
        }

        .role-bootstrap-table-wrap {
            max-height: none;
        }

        .role-table-toolbar {
            grid-template-columns: 1fr 150px;
        }

        .role-table-count {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 720px) {
        .role-table-hero,
        .role-table-panel-head {
            padding: 14px;
        }

        .role-table-actions,
        .role-table-actions .btn,
        .role-count-pill {
            width: 100%;
        }

        .role-row-actions {
            text-align: left;
        }

        .role-description {
            white-space: normal;
        }

        .role-table-toolbar,
        .role-table-pagination {
            align-items: stretch;
            grid-template-columns: 1fr;
        }

        .role-table-pagination {
            flex-direction: column;
        }

        .role-table-pagination .btn,
        .role-table-pagination .badge,
        .role-table-count {
            width: 100%;
        }
    }
</style>

<script>
(() => {
    const search = document.getElementById('roleTableSearch');
    const pageSize = document.getElementById('roleTablePageSize');
    const prev = document.getElementById('rolePrevPageBtn');
    const next = document.getElementById('roleNextPageBtn');
    const pageInfo = document.getElementById('rolePageInfo');
    const count = document.getElementById('roleTableCount');
    const rows = Array.from(document.querySelectorAll('#roleTable tbody tr'));
    let currentPage = 1;

    if (!rows.length) return;

    const render = (resetPage = false) => {
        if (resetPage) currentPage = 1;
        const query = (search?.value || '').trim().toLowerCase();
        const size = Number.parseInt(pageSize?.value || '10', 10) || 10;
        const matched = rows.filter((row) => !query || row.innerText.toLowerCase().includes(query));
        const totalPages = Math.max(1, Math.ceil(matched.length / size));
        currentPage = Math.min(Math.max(currentPage, 1), totalPages);
        const visibleSet = new Set(matched.slice((currentPage - 1) * size, currentPage * size));

        rows.forEach((row) => {
            row.classList.toggle('role-row-hidden', !visibleSet.has(row));
        });

        if (count) count.textContent = `${matched.length}/${rows.length}`;
        if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
        if (prev) prev.disabled = currentPage <= 1;
        if (next) next.disabled = currentPage >= totalPages;
    };

    search?.addEventListener('input', () => render(true));
    pageSize?.addEventListener('change', () => render(true));
    prev?.addEventListener('click', () => { currentPage -= 1; render(); });
    next?.addEventListener('click', () => { currentPage += 1; render(); });
    render(true);
})();
</script>
