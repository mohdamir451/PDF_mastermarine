@{
    var crumbs = ViewData["Breadcrumbs"] as IEnumerable<string>;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var fallback = new[] { "Admin", controller, action };
    var list = (crumbs ?? fallback).ToList();
}
<nav class="breadcrumbs" aria-label="Breadcrumb">
    @for (var i = 0; i < list.Count; i++)
    {
        var isLast = i == list.Count - 1;
        var label = list[i];
        if (isLast)
        {
            <span class="crumb current" aria-current="page">@label</span>
        }
        else if (i == 0)
        {
            <a class="crumb" href="@Url.Action("Index", "Dashboard")">@label</a>
        }
        else if (i == 1)
        {
            <a class="crumb" href="@Url.Action("Index", controller)">@label</a>
        }
        else
        {
            <span class="crumb">@label</span>
        }
        if (!isLast)
        {
            <span class="crumb-sep">/</span>
        }
    }
</nav>
