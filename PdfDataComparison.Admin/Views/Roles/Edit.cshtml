@model string
@{
    ViewData["Title"] = "Edit Role";
    ViewData["Subtitle"] = "Adjust role metadata and governance notes.";
}

<section class="page-hero">
    <div>
        <h2>Edit Role</h2>
        <p>Update role context and prepare permission updates.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to Roles</a>
</section>

<section class="card form-card">
    <div class="alert warning">Role editing is awaiting backend command wiring. Viewing role id <strong>@Model</strong>.</div>

    <div class="form-grid">
        <div class="form-group">
            <label>Role ID</label>
            <input value="@Model" readonly />
        </div>
        <div class="form-group">
            <label>Role Name</label>
            <input placeholder="Operations Admin" />
        </div>
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea rows="3" placeholder="Role responsibility summary"></textarea>
    </div>

    <div class="toolbar">
        <button class="btn btn-primary" type="button" disabled aria-disabled="true">Save Role (Pending Backend)</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</section>
