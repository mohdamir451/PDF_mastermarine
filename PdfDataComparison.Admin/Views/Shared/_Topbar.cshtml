@{
    var subtitle = ViewData["Subtitle"]?.ToString() ?? "Enterprise PDF Data Comparison Console";
    var name = User.Identity?.Name ?? "User";
    var initials = name.Length >= 2 ? name[..2].ToUpperInvariant() : name.ToUpperInvariant();
}
<header class="topbar topbar-minimal" id="topbar">
    <div class="topbar-left">
        <button type="button" class="icon-btn" id="sidebarToggle" aria-label="Toggle sidebar">
            <svg viewBox="0 0 24 24" class="icon-svg"><path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/></svg>
        </button>
        @await Html.PartialAsync("_Breadcrumbs")
    </div>

    <div class="topbar-center" aria-hidden="true"></div>

    <div class="topbar-actions">
        <button type="button" class="user-chip" data-dropdown-target="profileDropdown" aria-label="Open profile menu" aria-haspopup="menu" aria-expanded="false" aria-controls="profileDropdown">
            <span class="user-avatar">@initials</span>
            <span class="user-meta">
                <strong>@name</strong>
                <small>@subtitle</small>
            </span>
        </button>

        <form asp-controller="Account" asp-action="Logout" method="post" data-confirm="Sign out of this workspace?">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger-soft">Logout</button>
        </form>
    </div>

    @await Html.PartialAsync("_ProfileDropdown")
</header>
