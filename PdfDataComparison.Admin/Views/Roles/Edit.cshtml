@model RoleFormVm
@{
    ViewData["Title"] = "Edit Role";
    ViewData["Subtitle"] = "Adjust role metadata and governance notes.";
}

<section class="page-hero">
    <div>
        <h2>Edit Role</h2>
        <p>Update role context and prepare permission updates.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to Roles</a>
</section>

<section class="card form-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>
        <div class="form-grid">
        <div class="form-group">
            <label>Role ID</label>
            <input value="@Model.Id" readonly />
        </div>
        <div class="form-group">
            <label asp-for="Name">Role Name</label>
            <input asp-for="Name" placeholder="Operations Admin" />
            <span asp-validation-for="Name" class="field-validation-error"></span>
        </div>
        </div>

        <div class="form-group">
            <label asp-for="Description">Description</label>
            <textarea asp-for="Description" rows="3" placeholder="Role responsibility summary"></textarea>
        </div>

        <div class="toolbar">
            <button class="btn btn-primary" type="submit">Save Role</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
