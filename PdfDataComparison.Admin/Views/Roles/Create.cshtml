@{
    ViewData["Title"] = "Create Role";
    ViewData["Subtitle"] = "Define role identity and purpose.";
}

<section class="page-hero">
    <div>
        <h2>Create Role</h2>
        <p>Establish a new role before assigning page permissions.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to Roles</a>
</section>

<section class="card form-card">
    <div class="alert warning">Role creation is awaiting backend command wiring. Form structure is finalized.</div>

    <div class="form-grid">
        <div class="form-group">
            <label>Role Name</label>
            <input placeholder="Operations Admin" />
            <span class="form-help">Use a clear and unique name for admin readability.</span>
        </div>
        <div class="form-group">
            <label>Description</label>
            <input placeholder="Full operational access" />
        </div>
    </div>

    <div class="toolbar">
        <button class="btn btn-primary" type="button" disabled aria-disabled="true">Create Role (Pending Backend)</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</section>
