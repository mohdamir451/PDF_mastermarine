@model UserEditVm
@{
    ViewData["Title"] = "Edit User";
    ViewData["Subtitle"] = "Update profile details, account status, and role membership.";
}

<section class="page-hero">
    <div>
        <h2>Edit User</h2>
        <p>Update user metadata and role membership settings.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to Users</a>
</section>

<section class="card form-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert danger"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" autocomplete="name" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email" autocomplete="email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Department">Department</label>
                <input asp-for="Department" placeholder="Operations" />
                <span asp-validation-for="Department" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="RoleName">Role</label>
                <select asp-for="RoleName">
                    <option value="">No role</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
                <span asp-validation-for="RoleName" class="field-validation-error"></span>
            </div>
        </div>

        <label class="checkbox-row">
            <input asp-for="IsActive" />
            <span>Account is active</span>
        </label>

        <div class="toolbar">
            <button class="btn btn-primary" type="submit">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
