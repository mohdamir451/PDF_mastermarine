@model List<ReportHistoryItemVm>
@{
    ViewData["Title"] = "Reports / Export History";
    ViewData["Subtitle"] = "Submission archive with export access and traceability.";
}

<section class="report-table-page">
<header class="report-table-hero">
    <div>
        <h2>Reports & Export History</h2>
        <p>Track completed submissions and open detailed records for audit-ready exports.</p>
    </div>
    <span class="report-count-pill">@Model.Count submissions</span>
</header>

<section class="report-table-panel">
    <div class="report-table-panel-head">
        <div>
            <h3>Export History</h3>
            <p>Search submitted records and open report details.</p>
        </div>
    </div>

    <div class="loading-panel" data-loading-panel>
        <div class="skeleton-row"><span class="skeleton"></span><span class="skeleton"></span><span class="skeleton"></span></div>
        <div class="skeleton-row"><span class="skeleton"></span><span class="skeleton"></span><span class="skeleton"></span></div>
    </div>

    <div class="data-panel" data-data-panel hidden>
        @if (Model.Any())
        {
            <div class="report-table-toolbar" aria-label="Report table controls">
                <div class="report-table-search">
                    <label for="reportsQuickFilter">Search</label>
                    <input id="reportsQuickFilter" type="search" placeholder="Search reports..." />
                </div>
                <div class="report-table-page-size">
                    <label for="reportsPageSize">Rows</label>
                    <select id="reportsPageSize">
                        <option value="5">5 rows</option>
                        <option value="10" selected>10 rows</option>
                        <option value="25">25 rows</option>
                        <option value="50">50 rows</option>
                    </select>
                </div>
                <span class="report-table-count" id="reportsVisibleCount" aria-live="polite">0/0</span>
            </div>

            <div class="table-wrap report-bootstrap-table-wrap" id="reportsTableWrap">
                <table class="table table-responsive-card report-bootstrap-table" id="reportsTable">
                <thead>
                <tr>
                    <th scope="col">Submission ID</th>
                    <th scope="col">Type</th>
                    <th scope="col">Reference</th>
                    <th scope="col">Source File</th>
                    <th scope="col">Submitted By</th>
                    <th scope="col">Submitted At (UTC)</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Submission ID"><strong>#@item.Id</strong></td>
                        <td data-label="Type"><span class="badge neutral">@item.SourceType</span></td>
                        <td data-label="Reference" class="report-truncate" title="@item.Reference">@item.Reference</td>
                        <td data-label="Source File" class="report-truncate" title="@item.SourceFileName">@(string.IsNullOrWhiteSpace(item.SourceFileName) ? "-" : item.SourceFileName)</td>
                        <td data-label="Submitted By" class="report-truncate" title="@item.SubmittedByUserId">@(string.IsNullOrWhiteSpace(item.SubmittedByUserId) ? "-" : item.SubmittedByUserId)</td>
                        <td data-label="Submitted At (UTC)">@item.SubmittedAt.ToString("u")</td>
                        <td class="report-row-actions text-end" data-label="Actions">
                            @if (item.HasDetailsPage)
                            {
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-small">Details</a>
                            }
                            else
                            {
                                <a asp-controller="ComparisonJobs" asp-action="SubmittedPdfData" class="btn btn-secondary btn-small">PDF Data</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="report-table-pagination" aria-label="Report pages">
            <button type="button" class="btn btn-ghost btn-small" id="reportsPrevPageBtn">Previous</button>
            <span class="badge neutral" id="reportsPageInfo">Page 1 of 1</span>
            <button type="button" class="btn btn-ghost btn-small" id="reportsNextPageBtn">Next</button>
        </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">RP</div>
                <h3>No submissions yet</h3>
                <p>Completed comparisons will appear here once submitted.</p>
                <div class="empty-actions">
                    <a asp-controller="ComparisonJobs" asp-action="Index" class="btn btn-secondary">Open Comparison Queue</a>
                </div>
            </div>
        }
    </div>
</section>
</section>

<style>
    .report-table-page { display: grid; gap: 16px; }
    .report-table-hero,
    .report-table-panel {
        background: #fff;
        border: 1px solid #d9e2ef;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .045);
    }
    .report-table-hero {
        align-items: center;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        min-height: 76px;
        padding: 18px 24px;
    }
    .report-table-hero h2 {
        color: #0f172a;
        font-size: clamp(28px, 2.4vw, 38px);
        font-weight: 900;
        line-height: 1.05;
    }
    .report-table-hero p {
        color: #667085;
        font-size: 13px;
        margin-top: 6px;
    }
    .report-count-pill {
        align-items: center;
        background: #eef4ff;
        border: 1px solid #cfe0ff;
        border-radius: 999px;
        color: #1e3a8a;
        display: inline-flex;
        font-size: 12px;
        font-weight: 850;
        min-height: 34px;
        padding: 0 12px;
        white-space: nowrap;
    }
    .report-table-panel { overflow: hidden; }
    .report-table-panel-head {
        border-bottom: 1px solid #d9e2ef;
        padding: 14px 18px;
    }
    .report-table-panel-head h3 {
        color: #0f172a;
        font-size: 20px;
        font-weight: 900;
    }
    .report-table-panel-head p {
        color: #667085;
        font-size: 13px;
        margin-top: 4px;
    }
    .report-table-toolbar {
        align-items: end;
        background: #f8fafc;
        border-bottom: 1px solid #d9e2ef;
        display: grid;
        gap: 10px;
        grid-template-columns: minmax(260px, 1fr) 150px auto;
        padding: 10px 18px;
    }
    .report-table-search,
    .report-table-page-size { display: grid; gap: 4px; min-width: 0; }
    .report-table-search label,
    .report-table-page-size label {
        color: #344054;
        font-size: 11px;
        font-weight: 850;
    }
    .report-table-search input,
    .report-table-page-size select {
        border: 1px solid #d9e2ef;
        border-radius: 8px;
        color: #0f172a;
        font-size: 13px;
        min-height: 34px;
        padding: 0 10px;
        width: 100%;
    }
    .report-table-search input:focus,
    .report-table-page-size select:focus {
        border-color: #93c5fd;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, .13);
        outline: 0;
    }
    .report-table-count {
        align-items: center;
        align-self: end;
        background: #eef4ff;
        border: 1px solid #cfe0ff;
        border-radius: 8px;
        color: #1e3a8a;
        display: inline-flex;
        font-size: 12px;
        font-weight: 850;
        justify-content: center;
        min-height: 34px;
        min-width: 76px;
        padding: 0 10px;
    }
    .report-bootstrap-table-wrap {
        border: 0;
        border-radius: 0;
        box-shadow: none;
        max-height: calc(100vh - 290px);
        overflow: auto;
    }
    .report-bootstrap-table {
        margin: 0;
        table-layout: fixed;
        width: 100%;
    }
    .report-bootstrap-table thead th {
        background: #f8fafc;
        border-bottom: 1px solid #d9e2ef;
        color: #64748b;
        font-size: 11px;
        font-weight: 850;
        letter-spacing: .045em;
        padding: 10px 12px;
        position: sticky;
        text-transform: uppercase;
        top: 0;
        z-index: 2;
    }
    .report-bootstrap-table tbody td {
        border-bottom: 1px solid #edf2f7;
        color: #0f172a;
        font-size: 13px;
        height: 48px;
        padding: 8px 12px;
        vertical-align: middle;
    }
    .report-bootstrap-table tbody tr:nth-child(even) { background: #fbfcfe; }
    .report-bootstrap-table tbody tr:hover { background: #f8fbff; }
    .report-bootstrap-table th:nth-child(1),
    .report-bootstrap-table td:nth-child(1) { width: 12%; }
    .report-bootstrap-table th:nth-child(2),
    .report-bootstrap-table td:nth-child(2) { width: 13%; }
    .report-bootstrap-table th:nth-child(3),
    .report-bootstrap-table td:nth-child(3) { width: 17%; }
    .report-bootstrap-table th:nth-child(4),
    .report-bootstrap-table td:nth-child(4) { width: 20%; }
    .report-bootstrap-table th:nth-child(5),
    .report-bootstrap-table td:nth-child(5) { width: 16%; }
    .report-bootstrap-table th:nth-child(6),
    .report-bootstrap-table td:nth-child(6) { width: 14%; }
    .report-bootstrap-table th:nth-child(7),
    .report-bootstrap-table td:nth-child(7) { width: 8%; }
    .report-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .text-end { text-align: right; }
    .report-row-actions { white-space: nowrap; }
    .report-row-actions .btn { min-height: 30px; padding-inline: 10px; }
    .report-table-pagination {
        align-items: center;
        border-top: 1px solid #edf2f7;
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        padding: 10px 18px;
    }
    .report-table-pagination .btn,
    .report-table-pagination .badge { min-height: 32px; }
    .report-table-pagination .btn:disabled {
        background: #f8fafc;
        border-color: #edf2f7;
        color: #94a3b8;
        cursor: not-allowed;
    }
    .report-table-pagination .badge {
        background: #eef4ff;
        border-color: #cfe0ff;
        color: #1e3a8a;
        font-weight: 850;
    }
    tr.report-row-hidden { display: none; }

    @@media (max-width: 900px) {
        .report-table-hero { align-items: flex-start; flex-direction: column; }
        .report-bootstrap-table-wrap { max-height: none; }
        .report-table-toolbar { grid-template-columns: 1fr 150px; }
        .report-table-count { justify-content: flex-start; }
    }
    @@media (max-width: 720px) {
        .report-table-hero,
        .report-table-panel-head { padding: 14px; }
        .report-count-pill { width: 100%; }
        .report-row-actions { text-align: left; }
        .report-truncate { white-space: normal; }
        .report-table-toolbar { grid-template-columns: 1fr; }
        .report-table-pagination {
            align-items: stretch;
            flex-direction: column;
        }
        .report-table-pagination .btn,
        .report-table-pagination .badge,
        .report-table-count { width: 100%; }
    }
</style>

<script>
(() => {
    const search = document.getElementById('reportsQuickFilter');
    const pageSize = document.getElementById('reportsPageSize');
    const prev = document.getElementById('reportsPrevPageBtn');
    const next = document.getElementById('reportsNextPageBtn');
    const pageInfo = document.getElementById('reportsPageInfo');
    const count = document.getElementById('reportsVisibleCount');
    const body = document.querySelector('#reportsTable tbody');
    const rows = Array.from(document.querySelectorAll('#reportsTable tbody tr'));
    const emptyRow = document.createElement('tr');
    emptyRow.className = 'table-empty-row';
    emptyRow.hidden = true;
    emptyRow.innerHTML = '<td colspan="7">No reports match the current search.</td>';
    body?.appendChild(emptyRow);
    let currentPage = 1;

    if (!rows.length) return;

    const render = (resetPage = false) => {
        if (resetPage) currentPage = 1;
        const query = (search?.value || '').trim().toLowerCase();
        const size = Number.parseInt(pageSize?.value || '10', 10) || 10;
        const matched = rows.filter((row) => !query || row.innerText.toLowerCase().includes(query));
        const totalPages = Math.max(1, Math.ceil(matched.length / size));
        currentPage = Math.min(Math.max(currentPage, 1), totalPages);
        const visibleSet = new Set(matched.slice((currentPage - 1) * size, currentPage * size));

        rows.forEach((row) => row.classList.toggle('report-row-hidden', !visibleSet.has(row)));
        emptyRow.hidden = matched.length !== 0;
        if (count) count.textContent = `${matched.length}/${rows.length}`;
        if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
        if (prev) prev.disabled = currentPage <= 1;
        if (next) next.disabled = currentPage >= totalPages;
    };

    search?.addEventListener('input', () => render(true));
    pageSize?.addEventListener('change', () => render(true));
    prev?.addEventListener('click', () => { currentPage -= 1; render(); });
    next?.addEventListener('click', () => { currentPage += 1; render(); });
    render(true);
})();
</script>
