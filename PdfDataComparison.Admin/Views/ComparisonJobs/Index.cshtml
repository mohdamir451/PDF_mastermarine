@model ComparisonJobsIndexVm
@{
    ViewData["Title"] = "PDF Comparison Jobs";
    ViewData["Subtitle"] = "Track job intake, status, and comparison readiness.";
}

<section class="page-hero">
    <div>
        <h2>PDF Comparison Jobs</h2>
    </div>
</section>

<section class="card" id="pdfCompareSection">
    <h3 class="card-title">PDF API Compare</h3>

    <div id="pdfUploadPanel">
        <form id="pdfCompareForm" class="grid" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="pdfFileInput">PDF File</label>
                <input id="pdfFileInput" name="pdfFile" type="file" accept="application/pdf,.pdf" required />
            </div>

            <div class="action-bar">
                <div class="table-tools">
                    <button type="submit" class="btn btn-primary" id="pdfCompareSubmitBtn">Upload & Compare</button>
                    <span class="badge neutral" id="pdfCompareStatus">Waiting for upload</span>
                </div>
                <div class="table-tools">
                    <span class="badge success" id="matchCountBadge" hidden>Matches: 0</span>
                    <span class="badge danger" id="mismatchCountBadge" hidden>Issues: 0</span>
                </div>
            </div>
        </form>

        <div class="alert warning" id="pdfCompareError" hidden></div>
    </div>

    <div id="pdfCompareResult" class="validation-shell" hidden>
        <div class="validation-summary-grid" aria-label="Comparison summary">
            <div class="validation-summary-card">
                <strong id="summaryTotalFields">0</strong>
                <span>Total Fields</span>
            </div>
            <div class="validation-summary-card">
                <strong id="summaryMatches">0</strong>
                <span>Matches</span>
            </div>
            <div class="validation-summary-card issue">
                <strong id="mismatchCount">0</strong>
                <span>Issues</span>
            </div>
            <div class="validation-summary-card accuracy">
                <strong id="summaryAccuracy">0%</strong>
                <span>Accuracy</span>
            </div>
        </div>
        <div class="validation-progress" aria-label="Validation progress">
            <div class="validation-progress-label">
                <span>Validation Progress</span>
                <strong id="validationProgressText">0 / 0 Fields Validated</strong>
            </div>
            <div class="validation-progress-track"><span id="validationProgressBar"></span></div>
        </div>

        <div class="validation-toolbar sticky-primary-action">
            <div class="validation-title">
                <h3>Validation Workspace</h3>
                <p class="form-help">Review evidence, resolve issues, then save the validated record.</p>
            </div>
            <div class="workspace-command-bar">
                <div class="workspace-command-secondary" aria-label="View controls">
                    <span class="command-label">View Mode</span>
                    <button type="button" class="btn btn-secondary is-active" data-workspace-view="side-by-side">Side by Side</button>
                    <button type="button" class="btn btn-ghost" data-workspace-view="pdf-focus">PDF Only</button>
                    <button type="button" class="btn btn-ghost" data-workspace-view="matrix-focus">Matrix Only</button>
                </div>
                <div class="workspace-command-secondary" aria-label="Review controls">
                    <span class="command-label">Issue Navigation</span>
                    <button type="button" class="btn btn-ghost" id="prevMismatchBtn">← Previous Issue</button>
                    <span class="issue-counter-pill" id="issueCounterPill">Issue 0 of 0</span>
                    <button type="button" class="btn btn-ghost" id="nextMismatchBtn">Next Issue →</button>
                </div>
                <div class="workspace-command-secondary" aria-label="Filter controls">
                    <label for="matrixSearchInput" class="sr-only">Search fields</label>
                    <input id="matrixSearchInput" type="search" placeholder="Search fields or values..." />
                    <select id="matrixStatusFilter" aria-label="Filter by status">
                        <option value="all" selected>All statuses</option>
                        <option value="issue">Issues only</option>
                        <option value="match">Matches only</option>
                    </select>
                </div>
                <div class="workspace-command-secondary" aria-label="Export controls">
                    <label class="issue-toggle compact-check">
                        <input id="mismatchOnlyToggle" type="checkbox" />
                        <span class="toggle-track" aria-hidden="true"></span>
                        <span>Show issues only</span>
                    </label>
                    <button type="button" class="btn btn-ghost btn-icon" id="openPdfModalBtn" title="Open PDF popup" aria-label="Open PDF popup">PDF</button>
                    <button type="button" class="btn btn-ghost btn-icon" id="openMatrixModalBtn" title="Open matrix popup" aria-label="Open matrix popup">MTX</button>
                    <button type="button" class="btn btn-secondary" onclick="refreshPdf()">Refresh</button>
                    <button type="button" class="btn btn-secondary" id="uploadAnotherPdfBtn">Upload PDF</button>
                    <button type="button" class="btn btn-primary" id="indexSubmitBtn" hidden>Save Changes</button>
                </div>
            </div>
        </div>

        <div id="comparisonLayout" class="validation-workspace side-by-side">
            <section class="workspace-panel pdf-panel" aria-label="PDF viewer panel">
                <div class="workspace-panel-head">
                    <div>
                        <h3>PDF Viewer</h3>
                        <span id="pdfSourceLabel">Uploaded PDF</span>
                    </div>
                    <div class="pdf-viewer-tools" aria-label="PDF controls">
                        <button type="button" class="btn btn-ghost btn-small" onclick="refreshPdf()">Refresh</button>
                        <span class="badge neutral">Page 1</span>
                        <button type="button" class="btn btn-ghost btn-small" aria-label="Zoom out">−</button>
                        <button type="button" class="btn btn-ghost btn-small" aria-label="Zoom in">+</button>
                    </div>
                </div>
                <div class="pdf-scroll-region">
                    <div class="pdf-selection-pulse" id="pdfSelectionPulse" hidden></div>
                    <iframe id="uploadedPdfFrame" class="pdf-frame" title="Uploaded PDF preview"></iframe>
                </div>
            </section>

            <div class="workspace-resizer primary-resizer" role="separator" tabindex="0" aria-label="Resize PDF and comparison matrix"></div>

            <section class="workspace-panel matrix-panel" aria-label="Field comparison matrix panel">
                <div class="workspace-panel-head matrix-head">
                    <div>
                        <h3>Field Comparison Matrix</h3>
                        <span><strong id="matrixFieldCount">0 fields</strong> · <strong id="visibleMismatchCount">0</strong> visible issues</span>
                    </div>
                </div>
                <aside class="issue-panel" aria-label="Issues found">
                    <div class="issue-panel-head"><strong id="issuePanelTitle">Issues Found (0)</strong></div>
                    <div class="issue-list" id="issueList"></div>
                </aside>
                <div class="matrix-table-wrap">
                    <table class="table validation-table" id="pdfCompareTable">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Field</th>
                                <th>API Value</th>
                                <th>PDF Value</th>
                            </tr>
                        </thead>
                        <tbody id="pdfCompareTableBody"></tbody>
                    </table>
                </div>
            </section>

            <div class="workspace-resizer details-resizer" role="separator" tabindex="0" aria-label="Resize matrix and details panel"></div>

            <aside class="workspace-panel field-details-panel" aria-label="Selected field details">
                <div class="workspace-panel-head">
                    <div>
                        <h3>Field Details</h3>
                        <span id="selectedFieldStatus">No field selected</span>
                    </div>
                </div>
                <div class="field-detail-body" id="fieldDetailBody">
                    <div class="empty-state compact-empty">
                        <h3>Select a field</h3>
                        <p>Choose a row to inspect source values, status, and validation action.</p>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>

<section class="card">
    <div class="action-bar">
        <div>
            <h3 class="card-title">Saved PDF Data</h3>
            <p class="form-help">Submitted PDF validation records now live on a dedicated review page.</p>
        </div>
        <a asp-action="SubmittedPdfData" class="btn btn-primary">Open Submitted PDF Data</a>
    </div>
</section>

<div class="modal-backdrop compare-modal-backdrop" id="pdfPreviewModal" aria-hidden="true">
    <div class="modal-card compare-modal-card" role="dialog" aria-modal="true" aria-labelledby="pdfPreviewModalTitle">
        <div class="compare-modal-head">
            <h3 id="pdfPreviewModalTitle">PDF Preview</h3>
            <button type="button" class="btn btn-ghost btn-small" data-close-modal="pdfPreviewModal">Close</button>
        </div>
        <div class="compare-modal-body pdf-modal-body">
            <iframe id="pdfPreviewModalFrame" class="compare-modal-pdf-frame" title="PDF Preview Popup"></iframe>
        </div>
    </div>
</div>

<div class="modal-backdrop compare-modal-backdrop" id="matrixPreviewModal" aria-hidden="true">
    <div class="modal-card compare-modal-card compare-modal-card-wide" role="dialog" aria-modal="true" aria-labelledby="matrixPreviewModalTitle">
        <div class="compare-modal-head">
            <h3 id="matrixPreviewModalTitle">Field Comparison Matrix</h3>
            <button type="button" class="btn btn-ghost btn-small" data-close-modal="matrixPreviewModal">Close</button>
        </div>
        <div class="compare-modal-body">
            <div class="table-wrap" id="matrixPreviewTableWrap"></div>
        </div>
    </div>
</div>

<div class="drawer-backdrop" id="savedSubmissionPreviewModal" aria-hidden="true">
    <aside class="detail-drawer" role="dialog" aria-modal="true" aria-label="Saved PDF data details">
        <div class="drawer-head">
            <div>
                <h3 id="savedPreviewTitle">Saved PDF Data</h3>
                <p class="form-help" id="savedPreviewMeta">Review saved payload details.</p>
            </div>
            <button type="button" class="btn btn-ghost btn-small" data-close-modal="savedSubmissionPreviewModal">Close</button>
        </div>
        <div class="drawer-tabs" role="tablist" aria-label="Saved data preview tabs">
            <button type="button" class="drawer-tab is-active" data-saved-preview-tab="summary">Summary</button>
            <button type="button" class="drawer-tab" data-saved-preview-tab="values">Field Values</button>
            <button type="button" class="drawer-tab" data-saved-preview-tab="json">Raw JSON</button>
        </div>
        <div class="drawer-body">
            <div class="drawer-pane is-active" data-saved-preview-pane="summary">
                <div class="saved-summary-list" id="savedPreviewSummary"></div>
            </div>
            <div class="drawer-pane" data-saved-preview-pane="values">
                <div class="matrix-filters saved-values-filter">
                    <input id="savedPreviewSearch" type="search" placeholder="Search saved fields..." />
                    <label class="checkbox-row compact-check">
                        <input id="savedPreviewIssuesOnly" type="checkbox" />
                        <span>Issues only</span>
                    </label>
                </div>
                <div class="table-wrap saved-values-wrap">
                    <table class="table validation-table">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Expected API Value</th>
                                <th>Actual PDF Value</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="savedPreviewFieldBody"></tbody>
                    </table>
                </div>
                <div class="empty-state compact-empty" id="savedPreviewNoValues" hidden>
                    <h3>No saved fields match</h3>
                    <p>Adjust search or mismatch filter.</p>
                </div>
            </div>
            <div class="drawer-pane" data-saved-preview-pane="json">
                <pre class="json-preview saved-preview-json" id="savedPreviewJson"></pre>
            </div>
        </div>
    </aside>
</div>

<div class="toast-stack" id="toastStack" aria-live="polite" aria-atomic="true"></div>

<style>
    #pdfCompareTable td {
        vertical-align: top;
    }

    .json-details {
        max-width: 680px;
    }

    .json-preview {
        max-width: min(680px, 70vw);
        max-height: 220px;
        overflow: auto;
        margin-top: 10px;
        padding: 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: #f8fafc;
        color: var(--text);
        white-space: pre-wrap;
        word-break: break-word;
        font-size: 12px;
        line-height: 1.5;
    }

    html[data-theme="dark"] .json-preview {
        background: #121a2d;
    }

    .saved-preview-json {
        max-height: 68vh;
        max-width: none;
        margin: 0;
    }

    .workspace-nav {
        position: sticky;
        top: 0;
        z-index: 15;
        display: flex;
        gap: 4px;
        margin: -10px 0 10px;
        padding: 4px;
        width: max-content;
        border: 1px solid #dbe5f1;
        border-radius: 12px;
        background: var(--bg);
    }

    .workspace-nav a {
        border: 0;
        border-radius: 9px;
        color: var(--text-muted);
        font-size: 13px;
        font-weight: 800;
        padding: 7px 12px;
        text-decoration: none;
        background: transparent;
    }

    .workspace-nav a:hover {
        color: var(--text);
        border-color: var(--primary);
    }

    .submitted-data-head {
        align-items: flex-start;
        gap: 16px;
    }

    .submitted-summary-grid {
        display: grid;
        gap: 10px;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        margin: 14px 0 16px;
    }

    .submitted-summary-card {
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        padding: 12px;
    }

    .submitted-summary-card span {
        color: var(--text-muted);
        display: block;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .submitted-summary-card strong {
        color: var(--title);
        display: block;
        font-size: 22px;
        margin-top: 6px;
    }

    .submitted-summary-card.success {
        border-color: color-mix(in srgb, #16a34a 34%, var(--border));
    }

    .submitted-summary-card.warning {
        border-color: color-mix(in srgb, #f59e0b 42%, var(--border));
    }

    .segmented-control {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        padding: 3px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface-muted);
    }

    .segment-btn {
        min-height: 32px;
        padding: 0 12px;
        border: 0;
        border-radius: 6px;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        font: inherit;
    }

    .segment-btn.is-active {
        background: var(--surface);
        box-shadow: var(--shadow-sm);
        color: var(--text);
        font-weight: 700;
    }

    .submitted-filter-grid {
        align-items: end;
        display: grid;
        gap: 12px;
        grid-template-columns: minmax(220px, 1.4fr) minmax(150px, .7fr) minmax(140px, .6fr) minmax(140px, .6fr) auto;
        margin-bottom: 12px;
    }

    .submitted-sticky-toolbar {
        position: sticky;
        top: 48px;
        z-index: 12;
        padding: 10px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: color-mix(in srgb, var(--surface) 94%, transparent);
        backdrop-filter: blur(10px);
    }

    .submitted-export-actions {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }

    .field-count-note {
        color: var(--text-muted);
        display: block;
        font-size: 12px;
        margin-top: 4px;
        white-space: nowrap;
    }

    .status-chip-visual::before {
        content: "";
        display: inline-block;
        width: 7px;
        height: 7px;
        margin-right: 6px;
        border-radius: 999px;
        background: currentColor;
        vertical-align: middle;
    }

    tr.submitted-row-hidden {
        display: none;
    }

    tr[data-active="false"] {
        background: color-mix(in srgb, var(--surface-muted) 65%, transparent);
    }

    .saved-row-json {
        display: none;
    }

    #savedSubmissionPreviewModal.drawer-backdrop {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: none;
        align-items: stretch;
        justify-content: flex-end;
        background: rgba(15, 23, 42, .55);
    }

    #savedSubmissionPreviewModal.drawer-backdrop.is-open {
        display: flex;
    }

    #savedSubmissionPreviewModal.drawer-backdrop.show {
        display: flex;
    }

    #savedSubmissionPreviewModal .detail-drawer {
        position: relative;
        z-index: 10001;
        flex: 0 0 760px;
        width: 760px;
        max-width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: var(--surface, #ffffff);
        color: var(--text, #172033);
        box-shadow: -24px 0 60px rgba(15, 23, 42, .34);
        border-left: 1px solid var(--border, #dbe5f4);
    }

    .drawer-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 16px;
        border-bottom: 1px solid var(--border, #dbe5f4);
        background: var(--surface, #ffffff);
    }

    .drawer-head h3 {
        color: var(--title);
        margin: 0;
    }

    .drawer-tabs {
        display: flex;
        gap: 6px;
        padding: 10px 16px;
        border-bottom: 1px solid var(--border, #dbe5f4);
        background: var(--surface-muted, #f4f7fb);
    }

    .drawer-tab {
        border: 1px solid transparent;
        border-radius: 8px;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        font: inherit;
        font-weight: 700;
        padding: 8px 12px;
    }

    .drawer-tab.is-active {
        border-color: var(--border, #dbe5f4);
        background: var(--surface, #ffffff);
        color: var(--text, #172033);
    }

    .drawer-body {
        min-height: 0;
        flex: 1;
        overflow: auto;
        padding: 16px;
        background: var(--surface, #ffffff);
    }

    .drawer-pane {
        display: none;
    }

    .drawer-pane.is-active {
        display: block;
    }

    .saved-summary-list {
        display: grid;
        gap: 10px;
    }

    .saved-summary-item {
        display: grid;
        grid-template-columns: 190px minmax(0, 1fr);
        gap: 12px;
        padding: 12px;
        border: 1px solid var(--border, #dbe5f4);
        border-radius: 8px;
        background: var(--surface, #ffffff);
    }

    .saved-summary-item span {
        color: var(--text-muted);
        font-weight: 700;
    }

    .saved-values-filter {
        margin-bottom: 12px;
    }

    .saved-values-wrap {
        max-height: calc(100vh - 250px);
    }

    .toast-stack {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 100;
        display: grid;
        gap: 10px;
        width: min(380px, calc(100vw - 32px));
    }

    .app-toast {
        border: 1px solid var(--border);
        border-left: 4px solid var(--primary);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow-lg);
        color: var(--text);
        padding: 12px 14px;
        font-weight: 700;
    }

    @@media (max-width: 1080px) {
        .submitted-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .submitted-filter-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .submitted-export-actions {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 720px) {
        .workspace-nav,
        .submitted-data-head,
        .submitted-export-actions {
            align-items: stretch;
            flex-direction: column;
        }

        .submitted-summary-grid,
        .submitted-filter-grid {
            grid-template-columns: 1fr;
        }

        #savedSubmissionPreviewModal .detail-drawer {
            flex-basis: 100vw;
            width: 100vw;
        }
    }

    .validation-shell {
        display: grid;
        gap: 6px;
    }

    .validation-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
    }

    .validation-summary-card {
        border: 1px solid #dbe5f1;
        background: linear-gradient(180deg, #fff, #fbfdff);
        border-radius: 12px;
        padding: 9px 12px;
        min-height: 58px;
        display: grid;
        align-content: center;
        gap: 4px;
        box-shadow: 0 3px 10px rgba(15, 23, 42, .04);
    }

    .validation-summary-card span {
        color: var(--muted);
        font-size: 10.5px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .validation-summary-card strong {
        color: var(--title);
        font-size: 24px;
        line-height: 1;
    }

    .validation-summary-card:nth-child(2) strong { color: #15803d; }

    .validation-summary-card.issue strong {
        color: #b91c1c;
    }

    .validation-summary-card.accuracy strong {
        color: #1d4ed8;
    }

    .validation-progress {
        display: grid;
        gap: 5px;
        padding: 8px 10px;
        border: 1px solid #dbe5f1;
        border-radius: 12px;
        background: #fff;
    }

    .validation-progress-label {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--muted);
        font-size: 12px;
    }

    .validation-progress-label strong {
        color: var(--title);
    }

    .validation-progress-track {
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: #e5edf7;
    }

    .validation-progress-track span {
        display: block;
        width: 0%;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #2563eb, #60a5fa);
        transition: width .2s ease;
    }

    .validation-toolbar {
        position: sticky;
        top: 0;
        z-index: 18;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: rgba(255, 255, 255, .96);
        backdrop-filter: blur(10px);
        min-height: 56px;
        padding: 8px;
        display: block;
        gap: 8px;
        box-shadow: 0 8px 22px rgba(15, 23, 42, .045);
        overflow: visible;
    }

    html[data-theme="dark"] .validation-toolbar {
        background: rgba(18, 26, 45, .96);
    }

    .validation-title {
        display: none;
    }

    .validation-title h3,
    .workspace-panel-head h3 {
        color: var(--title);
        font-size: 14px;
        line-height: 1.2;
    }

    .validation-title .form-help {
        max-width: 150px;
        margin: 1px 0 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .workspace-command-bar,
    .workspace-command-secondary {
        display: flex;
        align-items: center;
        gap: 5px;
        flex-wrap: wrap;
    }

    .workspace-command-bar {
        display: flex;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 8px;
        width: 100%;
    }

    .workspace-command-secondary {
        flex: 0 0 auto;
        min-height: 32px;
        padding: 0;
        border: 0;
        border-radius: 0;
        background: transparent;
        flex-wrap: nowrap;
        gap: 8px;
    }

    .workspace-command-secondary[aria-label="View controls"] {
        display: none;
    }

    .workspace-command-secondary[aria-label="Review controls"] {
        order: 1;
    }

    .workspace-command-secondary[aria-label="Filter controls"] {
        order: 2;
        flex: 1 1 420px;
    }

    .workspace-command-secondary[aria-label="Export controls"] {
        order: 3;
        flex: 1 0 100%;
        justify-content: flex-end;
        padding-top: 8px;
        border-top: 1px solid #edf2f7;
    }

