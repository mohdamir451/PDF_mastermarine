<div class="theme-customizer" id="themeCustomizer" aria-hidden="true">
    <div class="customizer-head">
        <h3>Template Customizer</h3>
        <button type="button" class="icon-btn" data-customizer-close aria-label="Close customizer">✕</button>
    </div>

    <div class="customizer-block">
        <span>Sidebar Mode</span>
        <div class="choice-group">
            <button type="button" data-theme-set="sidebar" data-theme-value="expanded">Expanded</button>
            <button type="button" data-theme-set="sidebar" data-theme-value="collapsed">Collapsed</button>
        </div>
    </div>

    <div class="customizer-block">
        <span>Header Style</span>
        <div class="choice-group">
            <button type="button" data-theme-set="header" data-theme-value="sticky">Sticky</button>
            <button type="button" data-theme-set="header" data-theme-value="floating">Floating</button>
            <button type="button" data-theme-set="header" data-theme-value="static">Static</button>
        </div>
    </div>

    <div class="customizer-block">
        <span>Theme</span>
        <div class="choice-group">
            <button type="button" data-theme-set="mode" data-theme-value="light">Light</button>
            <button type="button" data-theme-set="mode" data-theme-value="dark">Dark</button>
            <button type="button" data-theme-set="mode" data-theme-value="system">System</button>
        </div>
    </div>

    <div class="customizer-block">
        <span>Direction</span>
        <div class="choice-group">
            <button type="button" data-theme-set="dir" data-theme-value="ltr">LTR</button>
            <button type="button" data-theme-set="dir" data-theme-value="rtl">RTL</button>
        </div>
    </div>
</div>
<button type="button" class="customizer-toggle" id="customizerToggle" aria-label="Open theme customizer">⚙</button>
