@model ProfileChangePasswordVm
@{
    ViewData["Title"] = "Profile / Change Password";
    ViewData["Subtitle"] = "Update account credentials and maintain secure access.";
}

<section class="page-hero">
    <div>
        <h2>Change Password</h2>
        <p>Use a strong password and keep credentials aligned with internal security policy.</p>
    </div>
</section>

<section class="card form-card profile-password-card">
    @if (TempData["Message"] != null)
    {
        <div class="alert success" role="status" aria-live="polite">@TempData["Message"]</div>
    }

    <form asp-action="ChangePassword" method="post" class="profile-password-form" data-clear-draft-on-submit>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert danger" role="alert" aria-live="assertive"></div>

        <div class="form-group password-row">
            <label asp-for="CurrentPassword" class="field-label required">Current Password</label>
            <input asp-for="CurrentPassword" autocomplete="current-password" />
            <button type="button" data-password-toggle="CurrentPassword">Show</button>
            <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
        </div>

        <div class="form-group password-row">
            <label asp-for="NewPassword" class="field-label required">New Password</label>
            <input asp-for="NewPassword" autocomplete="new-password" />
            <button type="button" data-password-toggle="NewPassword">Show</button>
            <span class="form-help">Minimum 8 characters. Include a digit and a special character.</span>
            <span asp-validation-for="NewPassword" class="field-validation-error"></span>
        </div>

        <div class="form-group password-row">
            <label asp-for="ConfirmPassword" class="field-label required">Confirm Password</label>
            <input asp-for="ConfirmPassword" autocomplete="new-password" />
            <button type="button" data-password-toggle="ConfirmPassword">Show</button>
            <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        </div>

        <div class="toolbar">
            <button class="btn btn-primary" type="submit">Update Password</button>
        </div>
    </form>
</section>

<style>
    .profile-password-card {
        max-width: 760px;
    }

    .profile-password-form {
        display: grid;
        gap: 16px;
    }

    .profile-password-form .alert:empty {
        display: none;
    }
</style>
