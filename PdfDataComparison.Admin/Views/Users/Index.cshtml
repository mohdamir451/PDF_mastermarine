@model PagedResult<UserListItemVm>
@{
    ViewData["Title"] = "User Management";
    ViewData["Subtitle"] = "Manage enterprise users, departments, and account status.";
    var searchQuery = Context.Request.Query["search"].ToString();
    var hasServerFilter = !string.IsNullOrWhiteSpace(searchQuery);
    var activeUsers = Model.Items.Count(x => x.IsActive);
    var inactiveUsers = Model.Items.Count(x => !x.IsActive);
    var usersWithRoles = Model.Items.Count(x => x.Roles.Any());
    var neverLoggedIn = Model.Items.Count(x => x.LastLoginAt == null);
}

<section class="admin-page-shell">
    <header class="admin-page-hero">
        <div class="admin-title-block">
            <h2>User Management</h2>
            <p>Control account access, role coverage, and user lifecycle visibility.</p>
        </div>
        <div class="admin-header-actions">
            <span class="admin-record-pill">@Model.TotalCount total users</span>
            <a asp-action="Create" class="btn btn-primary">Create User</a>
        </div>
    </header>

    <section class="admin-panel">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert success">@successMessage</div>
    }

    <div class="admin-summary-grid" aria-label="User management summary">
        <div class="admin-summary-card metric-active"><strong>@activeUsers</strong><span>Active Users</span></div>
        <div class="admin-summary-card metric-risk"><strong>@inactiveUsers</strong><span>Inactive Users</span></div>
        <div class="admin-summary-card metric-complete"><strong>@usersWithRoles</strong><span>With Roles</span></div>
        <div class="admin-summary-card metric-neutral"><strong>@neverLoggedIn</strong><span>Never Logged In</span></div>
    </div>

    <form method="get" class="admin-toolbar">
        <div class="admin-filter-group">
            <label for="usersSearch" class="sr-only">Search users</label>
            <input id="usersSearch" type="search" name="search" value="@searchQuery" placeholder="Search by name, email, or department" aria-label="Search users" />
            <button type="submit" class="btn btn-secondary">Search</button>
            <a asp-action="Index" class="btn btn-ghost">Reset</a>
        </div>
        <div class="admin-table-tools">
            @if (hasServerFilter)
            {
                <span class="active-filter-chip">Filter: @searchQuery</span>
            }
            <label for="usersQuickFilter" class="sr-only">Quick filter loaded rows</label>
            <input id="usersQuickFilter" class="table-quick-filter" type="search" placeholder="Quick filter visible rows" data-table-search data-table-target="usersTable" data-table-count-target="usersVisibleCount" />
            <span class="badge neutral visible-count" id="usersVisibleCount" aria-live="polite">0/0</span>
            <button type="button" class="btn btn-ghost" data-density-target="usersTableWrap" aria-pressed="false">Compact Rows</button>
        </div>
    </form>

    <div class="loading-panel" data-loading-panel>
        <div class="skeleton-row"><span class="skeleton"></span><span class="skeleton"></span><span class="skeleton"></span></div>
        <div class="skeleton-row"><span class="skeleton"></span><span class="skeleton"></span><span class="skeleton"></span></div>
    </div>

    <div class="data-panel" data-data-panel hidden>
        @if (Model.Items.Any())
        {
            <div class="table-wrap admin-table-wrap" id="usersTableWrap">
                <table class="table table-responsive-card admin-data-table" id="usersTable" data-sortable>
                    <thead>
                    <tr>
                        <th><button type="button" class="sort-btn" data-sort-col="0">Name</button></th>
                        <th><button type="button" class="sort-btn" data-sort-col="1">Email</button></th>
                        <th><button type="button" class="sort-btn" data-sort-col="2">Department</button></th>
                        <th><button type="button" class="sort-btn" data-sort-col="3">Status</button></th>
                        <th><button type="button" class="sort-btn" data-sort-col="4">Roles</button></th>
                        <th><button type="button" class="sort-btn" data-sort-col="5">Last Login</button></th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var user in Model.Items)
                    {
                        <tr>
                            <td data-label="Name">
                                <strong>@user.FullName</strong>
                            </td>
                            <td data-label="Email" class="admin-truncate" title="@user.Email">@user.Email</td>
                            <td data-label="Department" class="admin-truncate" title="@user.Department">@user.Department</td>
                            <td data-label="Status">
                                <span class="badge @(user.IsActive ? "success" : "danger") status-chip">@(user.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td data-label="Roles" class="admin-truncate" title="@string.Join(", ", user.Roles)">@string.Join(", ", user.Roles)</td>
                            <td data-label="Last Login">@(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                            <td class="actions" data-label="Actions">
                                <details class="row-menu admin-row-menu">
                                    <summary>Actions</summary>
                                    <div class="row-menu-list">
                                        <a asp-action="Edit" asp-route-id="@user.Id">Edit User</a>
                                        <a asp-action="ResetPassword" asp-route-id="@user.Id">Reset Password</a>
                                    </div>
                                </details>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="pagination" aria-label="User pages">
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.Page)
                        {
                            <span class="active">@i</span>
                        }
                        else
                        {
                            <a asp-action="Index" asp-route-page="@i" asp-route-search="@searchQuery">@i</a>
                        }
                    }
                </nav>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon">US</div>
                <h3>No users found</h3>
                <p>No accounts matched the current filters.</p>
                <div class="empty-actions">
                    <a asp-action="Create" class="btn btn-primary">Create User</a>
                    <a asp-action="Index" class="btn btn-ghost">Clear Filters</a>
                </div>
            </div>
        }
    </div>
    </section>
</section>
