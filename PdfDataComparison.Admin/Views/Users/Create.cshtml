@{
    ViewData["Title"] = "Create User";
    ViewData["Subtitle"] = "Prepare user profile and role assignment details.";
}

<section class="page-hero">
    <div>
        <h2>Create User</h2>
        <p>Define identity, department, and access settings for a new account.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to Users</a>
</section>

<section class="card form-card">
    <div class="alert warning">Create action is not connected to persistence yet. This screen now mirrors the final production form structure.</div>

    <div class="form-grid">
        <div class="form-group">
            <label>Full Name</label>
            <input placeholder="Enter full name" />
            <span class="form-help">Use the employee's official display name.</span>
        </div>
        <div class="form-group">
            <label>Email Address</label>
            <input type="email" placeholder="name@company.com" />
            <span class="form-help">Email must be unique in this workspace.</span>
        </div>
        <div class="form-group">
            <label>Department</label>
            <input placeholder="Operations" />
        </div>
        <div class="form-group">
            <label>Default Role</label>
            <select>
                <option>Admin</option>
                <option>Manager</option>
                <option>Reviewer</option>
                <option>DataEntry</option>
                <option>ReadOnly</option>
            </select>
        </div>
    </div>

    <label class="checkbox-row">
        <input type="checkbox" checked />
        <span>Activate account immediately</span>
    </label>

    <div class="toolbar">
        <button class="btn btn-primary" type="button" disabled aria-disabled="true">Create User (Pending Backend)</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</section>
