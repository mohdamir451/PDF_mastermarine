@model RoleFormVm
@{
    ViewData["Title"] = "Create Role";
    ViewData["Subtitle"] = "Define role identity and purpose.";
}

<section class="page-hero">
    <div>
        <h2>Create Role</h2>
        <p>Establish a new role before assigning page permissions.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Back to Roles</a>
</section>

<section class="card form-card">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>
        <div class="form-grid">
        <div class="form-group">
            <label asp-for="Name">Role Name</label>
            <input asp-for="Name" placeholder="Operations Admin" />
            <span asp-validation-for="Name" class="field-validation-error"></span>
            <span class="form-help">Use a clear and unique name for admin readability.</span>
        </div>
        <div class="form-group">
            <label asp-for="Description">Description</label>
            <input asp-for="Description" placeholder="Full operational access" />
        </div>
        </div>

        <div class="toolbar">
            <button class="btn btn-primary" type="submit">Create Role</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
