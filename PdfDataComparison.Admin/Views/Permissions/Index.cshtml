@using PdfDataComparison.Admin.Domain.Entities
@{
    ViewData["Title"] = "Page Permissions";
    ViewData["Subtitle"] = "Review permission coverage by role and page.";
    var roles = ViewBag.Roles as List<ApplicationRole>;
    var pages = ViewBag.Pages as List<PagePermission>;
    var selectedRoleId = ViewBag.SelectedRoleId as string;
    var rolePermissions = ViewBag.RolePermissions as List<RolePermission> ?? new List<RolePermission>();

    static string EffectiveOperation(string permissionKey)
    {
        if (permissionKey.EndsWith(".Submit", StringComparison.OrdinalIgnoreCase)) return "Submit";
        if (permissionKey.EndsWith(".Export", StringComparison.OrdinalIgnoreCase)) return "Export";
        if (permissionKey.EndsWith(".Edit", StringComparison.OrdinalIgnoreCase)) return "Edit";
        if (permissionKey.EndsWith(".Manage", StringComparison.OrdinalIgnoreCase)) return "Edit";
        if (permissionKey.EndsWith(".Create", StringComparison.OrdinalIgnoreCase)) return "Create";
        if (permissionKey.EndsWith(".Delete", StringComparison.OrdinalIgnoreCase)) return "Delete";
        return "View";
    }
}

<section class="page-hero">
    <div>
        <h2>Permission Matrix</h2>
        <p>Inspect page-level access coverage and operational controls for each role.</p>
    </div>
</section>

<style>
    .permission-operation-pill {
        align-items: center;
        background: #eef4ff;
        border: 1px solid #cfe0ff;
        border-radius: 999px;
        color: #1e3a8a;
        display: inline-flex;
        font-size: 10.5px;
        font-weight: 850;
        margin-left: 8px;
        min-height: 22px;
        padding: 0 8px;
        vertical-align: middle;
        white-space: nowrap;
    }

    .permission-op {
        text-align: center;
    }

    .permission-op-na {
        background: #f8fafc;
        opacity: .55;
    }

    .permission-op-na input {
        cursor: not-allowed;
    }

    .permission-op-active {
        background: #fbfdff;
    }

    .permission-op-active input {
        cursor: pointer;
    }
</style>

<section class="card">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert success">@successMessage</div>
    }

    <form method="get" class="action-bar">
        <div class="filter-bar">
            <select name="roleId">
                <option value="">Select a role</option>
                @if (roles != null)
                {
                    foreach (var role in roles)
                    {
                        if (selectedRoleId == role.Id)
                        {
                            <option value="@role.Id" selected>@role.Name</option>
                        }
                        else
                        {
                            <option value="@role.Id">@role.Name</option>
                        }
                    }
                }
            </select>
            <button type="submit" class="btn btn-primary">Load Matrix</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(selectedRoleId))
        {
            <span class="badge neutral">@rolePermissions.Count rows with assigned permissions</span>
        }
    </form>

    @if (pages != null && pages.Any())
    {
        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="roleId" value="@selectedRoleId" />
            <div class="table-wrap permission-table-wrap">
                <table class="table permission-table">
                    <thead>
                    <tr>
                        <th>Page</th>
                        <th>Permission Key</th>
                        <th>View</th>
                        <th>Create</th>
                        <th>Edit</th>
                        <th>Delete</th>
                        <th>Submit</th>
                        <th>Export</th>
                    </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < pages.Count; i++)
                    {
                        var permissionPage = pages[i];
                        var permissions = rolePermissions.FirstOrDefault(x => x.PagePermissionId == permissionPage.Id);
                        var effectiveOperation = EffectiveOperation(permissionPage.PermissionKey);
                        <tr>
                            <td class="permission-page-cell">
                                <strong>@permissionPage.PageName</strong>
                                <span class="permission-operation-pill">@effectiveOperation</span>
                                <input type="hidden" name="permissions[@i].PagePermissionId" value="@permissionPage.Id" />
                            </td>
                            <td>@permissionPage.PermissionKey</td>
                            <td class="permission-op @(effectiveOperation == "View" ? "permission-op-active" : "permission-op-na")">
                                @if (effectiveOperation == "View" && permissions?.CanView == true)
                                {
                                    <input type="checkbox" name="permissions[@i].CanView" value="true" checked />
                                }
                                else if (effectiveOperation == "View")
                                {
                                    <input type="checkbox" name="permissions[@i].CanView" value="true" />
                                }
                                else
                                {
                                    <input type="checkbox" disabled aria-label="View is not applicable for @permissionPage.DisplayName" />
                                }
                                <input type="hidden" name="permissions[@i].CanView" value="false" />
                            </td>
                            <td class="permission-op @(effectiveOperation == "Create" ? "permission-op-active" : "permission-op-na")">
                                @if (effectiveOperation == "Create" && permissions?.CanCreate == true)
                                {
                                    <input type="checkbox" name="permissions[@i].CanCreate" value="true" checked />
                                }
                                else if (effectiveOperation == "Create")
                                {
                                    <input type="checkbox" name="permissions[@i].CanCreate" value="true" />
                                }
                                else
                                {
                                    <input type="checkbox" disabled aria-label="Create is not applicable for @permissionPage.DisplayName" />
                                }
                                <input type="hidden" name="permissions[@i].CanCreate" value="false" />
                            </td>
                            <td class="permission-op @(effectiveOperation == "Edit" ? "permission-op-active" : "permission-op-na")">
                                @if (effectiveOperation == "Edit" && permissions?.CanEdit == true)
                                {
                                    <input type="checkbox" name="permissions[@i].CanEdit" value="true" checked />
                                }
                                else if (effectiveOperation == "Edit")
                                {
                                    <input type="checkbox" name="permissions[@i].CanEdit" value="true" />
                                }
                                else
                                {
                                    <input type="checkbox" disabled aria-label="Edit is not applicable for @permissionPage.DisplayName" />
                                }
                                <input type="hidden" name="permissions[@i].CanEdit" value="false" />
                            </td>
                            <td class="permission-op @(effectiveOperation == "Delete" ? "permission-op-active" : "permission-op-na")">
                                @if (effectiveOperation == "Delete" && permissions?.CanDelete == true)
                                {
                                    <input type="checkbox" name="permissions[@i].CanDelete" value="true" checked />
                                }
                                else if (effectiveOperation == "Delete")
                                {
                                    <input type="checkbox" name="permissions[@i].CanDelete" value="true" />
                                }
                                else
                                {
                                    <input type="checkbox" disabled aria-label="Delete is not applicable for @permissionPage.DisplayName" />
                                }
                                <input type="hidden" name="permissions[@i].CanDelete" value="false" />
                            </td>
                            <td class="permission-op @(effectiveOperation == "Submit" ? "permission-op-active" : "permission-op-na")">
                                @if (effectiveOperation == "Submit" && permissions?.CanSubmit == true)
                                {
                                    <input type="checkbox" name="permissions[@i].CanSubmit" value="true" checked />
                                }
                                else if (effectiveOperation == "Submit")
                                {
                                    <input type="checkbox" name="permissions[@i].CanSubmit" value="true" />
                                }
                                else
                                {
                                    <input type="checkbox" disabled aria-label="Submit is not applicable for @permissionPage.DisplayName" />
                                }
                                <input type="hidden" name="permissions[@i].CanSubmit" value="false" />
                            </td>
                            <td class="permission-op @(effectiveOperation == "Export" ? "permission-op-active" : "permission-op-na")">
                                @if (effectiveOperation == "Export" && permissions?.CanExport == true)
                                {
                                    <input type="checkbox" name="permissions[@i].CanExport" value="true" checked />
                                }
                                else if (effectiveOperation == "Export")
                                {
                                    <input type="checkbox" name="permissions[@i].CanExport" value="true" />
                                }
                                else
                                {
                                    <input type="checkbox" disabled aria-label="Export is not applicable for @permissionPage.DisplayName" />
                                }
                                <input type="hidden" name="permissions[@i].CanExport" value="false" />
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="toolbar" style="margin-top:16px;">
                @if (string.IsNullOrWhiteSpace(selectedRoleId))
                {
                    <button type="submit" class="btn btn-primary" disabled>Select a Role Before Saving</button>
                }
                else
                {
                    <button type="submit" class="btn btn-primary">Save Permissions</button>
                }
            </div>
        </form>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">PM</div>
            <h3>No permission pages configured</h3>
            <p>Seed permissions to populate this matrix.</p>
        </div>
    }
</section>
